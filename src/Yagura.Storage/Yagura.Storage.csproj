<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" />
    <!--
      Microsoft.Data.Sqlite が許容する SQLitePCLRaw.core の最小版 (2.1.11) には既知の高深刻度
      脆弱性 CVE-2025-6965 がある。CPM の PackageVersion 引き上げを実際に有効化するため、
      直接 PackageReference として明示する（詳細は Directory.Packages.props のコメント参照）。
    -->
    <PackageReference Include="SQLitePCLRaw.core" />
    <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" />
    <!-- SQL Server provider（M5-3。Issue #47）。Directory.Packages.props のバージョン検証コメント参照。 -->
    <PackageReference Include="Microsoft.Data.SqlClient" />
  </ItemGroup>

  <ItemGroup>
    <!--
      スプールのフレーム形式（長さプレフィックス + CRC-32）・破損末尾検出は internal 実装
      （SpoolRecordSerializer・SpoolSegmentReader・Crc32）の単体テストで直接検証する
      （DiskSpool 経由のブラックボックステストだけでなく、フレーム境界の異常系を
      ピンポイントに再現するため）。M4-3 で追加。
    -->
    <InternalsVisibleTo Include="Yagura.Storage.Tests" />
    <!--
      スキーマ移行の適合テスト（v1 -> v2。Issue #145/#146/#147）が現行スキーマバージョン定数
      （CurrentSchemaVersion）と照合順序定数（SearchCollation）を検証で参照するため。
    -->
    <InternalsVisibleTo Include="Yagura.Storage.ConformanceTests" />
  </ItemGroup>

</Project>
