@page "/admin/forwarder-kit"
@namespace Yagura.Web.Administration.Screens
@layout AdminScreenLayout
@using Yagura.Web.ForwarderKit
@using Yagura.Web.Administration
@using Yagura.Web.Circuits
@inject INicCandidateSource NicCandidateSource
@inject IForwarderMsiSource MsiSource
@inject NavigationManager Navigation
@inject ForwarderMsiUploadRuntimeOptions UploadOptions
@inject AdminAuthenticationRuntimeOptions AuthOptions
@inject IForwarderMsiStore MsiStore
@inject IForwarderMsiPlacementService PlacementService
@inject YaguraCircuitContext CircuitContext
@inject YaguraCircuitAuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

@*
    フォワーダ配布キット生成画面（ADR-0008。管理リスナ帰属はレイアウトが担う）。

    - 宛先: NIC 候補のラジオリスト + 手入力。既定選択なし（設計条件 1——到達可能性の判断責任は
      管理者に残る。候補はループバック・リンクローカル/APIPA・無効 NIC を除外済み——
      NicCandidateFilter・SystemNicCandidateSource）
    - チャネル: System / Application 初期オン、Security 初期オフのオプトイン（設計条件 2）
    - MSI 同梱（設計条件 9）: 配置フォルダのフルパスを常時表示。未検出・単一検出・複数検出で
      画面を出し分ける。単一検出時のチェックボックスは初期オフ（オプトイン）。版不一致時は
      警告表示 → 明示確認チェックの二段階を要する
    - 生成: サーバ側で最終検証（ForwarderKitRequest.TryCreate）を必ず経由するため、本画面の
      検証はユーザー体験のための早期フィードバックに過ぎない（不正値でも生成 GET へは
      到達しうるが、その場合は 400 で弾かれる——YaguraAdminExtensions.MapForwarderKitDownload）
*@
<PageTitle>@UiText.ForwarderKitTitle - Yagura</PageTitle>

<MudText Typo="Typo.h5">@UiText.ForwarderKitTitle</MudText>
<MudText Class="mt-2">@UiText.ForwarderKitIntro</MudText>

<MudPaper Elevation="1" Class="pa-4 mt-4">
    <MudText Typo="Typo.h6">@UiText.ForwarderKitDestinationTitle</MudText>
    <MudText Typo="Typo.caption" Class="mb-2">@UiText.ForwarderKitDestinationNote</MudText>

    @if (_candidates.Count == 0)
    {
        <MudText Typo="Typo.caption" Class="mb-2">@UiText.ForwarderKitNoCandidates</MudText>
    }
    else
    {
        <div role="radiogroup" aria-label="@UiText.ForwarderKitDestinationTitle">
            @foreach (var candidate in _candidates)
            {
                <label class="yagura-checkbox-row d-block mb-1">
                    <input type="radio"
                           name="forwarder-kit-destination"
                           value="@candidate.Address"
                           checked="@(_selectedMode == DestinationMode.Candidate && _selectedAddress == candidate.Address)"
                           @onchange="() => SelectCandidate(candidate.Address)" />
                    <span class="yagura-monospace">@candidate.Address</span>
                    <MudText Typo="Typo.caption" Color="Color.Default" Inline="true" Class="ml-2">@candidate.Description</MudText>
                </label>
            }
        </div>
    }

    <label class="yagura-checkbox-row d-block mb-1 mt-2">
        <input type="radio"
               name="forwarder-kit-destination"
               value="manual"
               checked="@(_selectedMode == DestinationMode.Manual)"
               @onchange="SelectManual" />
        @UiText.ForwarderKitManualEntryOption
    </label>

    @if (_selectedMode == DestinationMode.Manual)
    {
        <YaguraTextField Label="@UiText.ForwarderKitManualEntryLabel"
                         Required="true"
                         @bind-Value="_manualHost" />
    }

    <YaguraTextField Label="@UiText.ForwarderKitPortLabel"
                     Required="true"
                     @bind-Value="_portText" />
</MudPaper>

<MudPaper Elevation="1" Class="pa-4 mt-4">
    <MudText Typo="Typo.h6">@UiText.ForwarderKitModeTitle</MudText>
    <MudText Typo="Typo.caption" Class="mb-2">@UiText.ForwarderKitModeNote</MudText>
    <div role="radiogroup" aria-label="@UiText.ForwarderKitModeTitle">
        <label class="yagura-checkbox-row d-block mb-1">
            <input type="radio"
                   name="forwarder-kit-mode"
                   value="udp"
                   checked="@(_selectedForwardMode == ForwarderKitMode.Udp)"
                   @onchange="() => SelectForwardMode(ForwarderKitMode.Udp)" />
            @UiText.ForwarderKitModeUdp
        </label>
        <label class="yagura-checkbox-row d-block mb-1">
            <input type="radio"
                   name="forwarder-kit-mode"
                   value="tcp"
                   checked="@(_selectedForwardMode == ForwarderKitMode.Tcp)"
                   @onchange="() => SelectForwardMode(ForwarderKitMode.Tcp)" />
            @UiText.ForwarderKitModeTcp
        </label>
    </div>
    @if (_selectedForwardMode == ForwarderKitMode.Tcp)
    {
        <MudText Typo="Typo.caption" Color="Color.Warning" role="alert">@UiText.ForwarderKitModeTcpNote</MudText>
    }
</MudPaper>

<MudPaper Elevation="1" Class="pa-4 mt-4">
    <MudText Typo="Typo.h6">@UiText.ForwarderKitChannelsTitle</MudText>

    <YaguraCheckboxField Label="@UiText.ForwarderKitChannelSystem" @bind-Value="_channelSystem" />
    <YaguraCheckboxField Label="@UiText.ForwarderKitChannelApplication" @bind-Value="_channelApplication" />
    <YaguraCheckboxField Label="@UiText.ForwarderKitChannelSecurity" @bind-Value="_channelSecurity" />

    @if (_channelSecurity)
    {
        <MudText Typo="Typo.caption" Color="Color.Warning" role="alert">@UiText.ForwarderKitSecurityChannelWarning</MudText>
    }
</MudPaper>

<MudPaper Elevation="1" Class="pa-4 mt-4">
    <MudText Typo="Typo.h6">@UiText.ForwarderKitContentsTitle</MudText>
    <ul>
        <li>fluent-bit-yagura.conf</li>
        <li>install.ps1</li>
        <li>uninstall.ps1</li>
        <li>winevt-severity.lua</li>
        <li>README.md</li>
        <li>GENERATED.txt</li>
        @if (_includeMsi)
        {
            <li>@_msiLookup!.Details!.FileName</li>
        }
    </ul>
    <MudText>@string.Format(UiText.ForwarderKitVerifiedVersionFormat, ForwarderKitConstraints.VerifiedFluentBitVersion)</MudText>
    @if (!_includeMsi)
    {
        <MudText Typo="Typo.caption">@UiText.ForwarderKitMsiNotIncludedNote</MudText>
    }
</MudPaper>

<MudPaper Elevation="1" Class="pa-4 mt-4">
    <MudText Typo="Typo.h6">@UiText.ForwarderKitMsiSectionTitle</MudText>
    <MudText Typo="Typo.caption" Class="mb-2">@string.Format(UiText.ForwarderKitMsiFolderPathFormat, MsiSource.FolderPath)</MudText>

    <MudText Typo="Typo.subtitle2" Class="mt-2">@UiText.ForwarderKitMsiArchitectureTitle</MudText>
    <MudText Typo="Typo.caption" Class="mb-2">@UiText.ForwarderKitMsiArchitectureNote</MudText>
    <div role="radiogroup" aria-label="@UiText.ForwarderKitMsiArchitectureTitle">
        <label class="yagura-checkbox-row d-block mb-1">
            <input type="radio"
                   name="forwarder-kit-msi-architecture"
                   value="x64"
                   checked="@(_selectedArchitecture == ForwarderMsiArchitecture.Win64)"
                   @onchange="() => SelectArchitecture(ForwarderMsiArchitecture.Win64)" />
            @UiText.ForwarderKitMsiArchitectureX64
        </label>
        <label class="yagura-checkbox-row d-block mb-1">
            <input type="radio"
                   name="forwarder-kit-msi-architecture"
                   value="arm64"
                   checked="@(_selectedArchitecture == ForwarderMsiArchitecture.WinArm64)"
                   @onchange="() => SelectArchitecture(ForwarderMsiArchitecture.WinArm64)" />
            @UiText.ForwarderKitMsiArchitectureArm64
        </label>
    </div>

    @switch (_msiLookup!.State)
    {
        case ForwarderMsiLookupState.NotFound:
            <MudText Typo="Typo.body2">@string.Format(UiText.ForwarderKitMsiNotFoundFormat, ForwarderMsiConstraints.GetFileNamePattern(_selectedArchitecture))</MudText>
            break;

        case ForwarderMsiLookupState.Multiple:
            <MudText Color="Color.Error" role="alert">@UiText.ForwarderKitMsiMultipleErrorTitle</MudText>
            <MudText Typo="Typo.caption">@UiText.ForwarderKitMsiMultipleListTitle</MudText>
            <ul>
                @foreach (var fileName in _msiLookup.MultipleCandidateFileNames ?? [])
                {
                    <li class="yagura-monospace">@fileName</li>
                }
            </ul>
            break;

        case ForwarderMsiLookupState.Single:
            var details = _msiLookup.Details!;
            <YaguraCheckboxField Label="@UiText.ForwarderKitMsiIncludeCheckbox" @bind-Value="_includeMsi" />

            @if (_includeMsi)
            {
                <MudText Typo="Typo.caption">@string.Format(UiText.ForwarderKitMsiDetectedFileNameFormat, details.FileName)</MudText>
                <MudText Typo="Typo.caption">
                    @string.Format(UiText.ForwarderKitMsiDetectedVersionFormat, _effectiveVersion ?? UiText.ForwarderKitMsiVersionUnknown)
                </MudText>
                <MudText Typo="Typo.caption">@string.Format(UiText.ForwarderKitMsiSha256Format, details.Sha256)</MudText>
                <MudText Typo="Typo.caption">@OfficialHashMatchText()</MudText>
                <MudText Typo="Typo.caption">@UiText.ForwarderKitMsiSizeNotice</MudText>

                @if (_versionMismatch)
                {
                    <MudText Color="Color.Warning" role="alert">
                        @string.Format(UiText.ForwarderKitMsiVersionMismatchWarningFormat, _effectiveVersion ?? UiText.ForwarderKitMsiVersionUnknown, ForwarderKitConstraints.VerifiedFluentBitVersion)
                    </MudText>
                    <YaguraCheckboxField Label="@UiText.ForwarderKitMsiVersionMismatchAcknowledge" @bind-Value="_versionMismatchAcknowledged" />
                }
            }
            break;
    }
</MudPaper>

<MudPaper Elevation="1" Class="pa-4 mt-4">
    <MudText Typo="Typo.h6">@UiText.ForwarderMsiUploadSectionTitle</MudText>

    @if (!UploadOptions.Enabled)
    {
        @* 条件不成立時は機能を表出させない。ただし沈黙にしない（ADR-0020 決定 1）——
           どの条件が欠けているかと手動配置ガイドへの導線を示す。 *@
        <MudText Typo="Typo.body2" Class="mt-2">@UiText.ForwarderMsiUploadDisabledTitle</MudText>
        <MudText Typo="Typo.caption" Class="mt-1">@UiText.ForwarderMsiUploadDisabledIntro</MudText>
        <ul>
            <li>
                @UiText.ForwarderMsiUploadConditionAuth
                @if (AuthOptions.WindowsAuthEnabled || AuthOptions.AppAuthEnabled)
                {
                    <MudText Typo="Typo.caption" Inline="true" Class="ml-1">（設定済み）</MudText>
                }
            </li>
            <li>
                @UiText.ForwarderMsiUploadConditionRequireForLoopback
                @if (AuthOptions.RequireAuthentication)
                {
                    <MudText Typo="Typo.caption" Inline="true" Class="ml-1">（設定済み）</MudText>
                }
                else
                {
                    @* 条件 (ii) の代償の提示（ADR-0020 決定 1——復旧経路のトレードオフを
                       知らずに輸入させない。ブレークグラス強推奨込み）。 *@
                    <MudText Typo="Typo.caption" Color="Color.Warning" role="alert" Class="d-block mt-1">
                        @UiText.ForwarderMsiUploadConditionRequireForLoopbackCost
                    </MudText>
                }
            </li>
            <li>@UiText.ForwarderMsiUploadConditionOptIn</li>
        </ul>
        <MudText Typo="Typo.caption">@UiText.ForwarderMsiUploadDisabledManualGuide</MudText>
    }
    else if (_writeAccess?.CanWrite != true)
    {
        @* 機能は有効だが書き込み経路が未開放（ACE 未付与。ADR-0020 決定 2）——ここも沈黙に
           しない。付与コマンドをコピー可能な形で示す。未開放の間はアップロード・削除の両方が
           実行不能（削除も「変更」権限を要するため——同決定）。 *@
        <MudText Typo="Typo.body2" Class="mt-2">@UiText.ForwarderMsiUploadNotWritableTitle</MudText>
        <MudText Typo="Typo.caption" Class="mt-1">@UiText.ForwarderMsiUploadNotWritableIntro</MudText>
        <MudText Class="yagura-monospace mt-1">
            @string.Format(UiText.ForwarderMsiUploadGrantCommandFormat, MsiStore.FolderPath, UploadOptions.ServiceAccountName ?? "NT SERVICE\\Yagura")
        </MudText>
    }
    else
    {
        @* 開放状態の常時表示（ADR-0020 決定 2——画面を開くたびに「開いている」ことが目に入る。
           閉じ忘れの検出可能性の一部）。 *@
        <MudText Typo="Typo.caption" Color="Color.Warning" role="status" Class="mt-2">
            @UiText.ForwarderMsiUploadWritePathOpenNotice
        </MudText>

        @if (_uploadNotice is not null)
        {
            <MudText Typo="Typo.body2" Color="Color.Success" role="status" Class="mt-2">@_uploadNotice</MudText>
        }

        @if (_uploadError is not null)
        {
            <MudText Typo="Typo.body2" Color="Color.Error" role="alert" Class="mt-2">@_uploadError</MudText>
        }

        @if (_stagedUpload is null)
        {
            <MudText Typo="Typo.subtitle2" Class="mt-3">@UiText.ForwarderMsiUploadFileLabel</MudText>
            <input type="file" accept=".msi" @ref="_fileInput" disabled="@_uploadInProgress" />
            <div class="mt-2">
                <YaguraButton Role="YaguraButtonRole.Normal" OnClick="UploadAsync" Disabled="@_uploadInProgress">
                    @UiText.ForwarderMsiUploadButton
                </YaguraButton>
            </div>
            @if (_uploadInProgress)
            {
                <MudText Typo="Typo.caption" role="status">@UiText.ForwarderMsiUploadInProgress</MudText>
            }

            @if (_msiLookup!.State == ForwarderMsiLookupState.Single && !_deleteConfirming)
            {
                <div class="mt-3">
                    <YaguraButton Role="YaguraButtonRole.Normal" OnClick="BeginDelete">@UiText.ForwarderMsiDeleteButton</YaguraButton>
                </div>
            }

            @if (_deleteConfirming && _msiLookup!.State == ForwarderMsiLookupState.Single)
            {
                @* 削除は配置と同じ重み——常に二段階確認（ADR-0020 決定 3。配置側の「不一致時のみ」
                   とは異なる無条件適用）。第一段 = 本パネル（削除前 SHA256 の提示 + 確認チェック）、
                   第二段 = Destructive ボタン内蔵の確認ダイアログ（ui.md §3.1——破壊的操作は
                   確認なしで実行できない構造）。 *@
                <MudText Typo="Typo.subtitle2" Class="mt-3">@UiText.ForwarderMsiDeleteConfirmTitle</MudText>
                <MudText Typo="Typo.caption">
                    @string.Format(UiText.ForwarderMsiDeleteConfirmDetailFormat, _msiLookup.Details!.FileName, _msiLookup.Details!.Sha256)
                </MudText>
                <YaguraCheckboxField Label="@UiText.ForwarderMsiDeleteAcknowledge" @bind-Value="_deleteAcknowledged" />
                <div class="mt-2">
                    <YaguraButton Role="YaguraButtonRole.Destructive"
                                  ConfirmTitle="@UiText.ForwarderMsiDeleteConfirmTitle"
                                  ConfirmSummary="@string.Format(UiText.ForwarderMsiDeleteConfirmDetailFormat, _msiLookup.Details!.FileName, _msiLookup.Details!.Sha256)"
                                  OnClick="ConfirmDeleteAsync">@UiText.ForwarderMsiDeleteConfirmButton</YaguraButton>
                    <YaguraButton Role="YaguraButtonRole.Normal" OnClick="CancelDelete">@UiText.ForwarderMsiDeleteCancelButton</YaguraButton>
                </div>
            }
        }
        else
        {
            @* stage → commit の二段階（ADR-0020 決定 3）: サーバが計算した SHA256・版・公式ハッシュ
               照合の結果を確認してから確定する。まだ配置は確定していない。 *@
            <MudText Typo="Typo.subtitle2" Class="mt-3">@UiText.ForwarderMsiUploadConfirmTitle</MudText>
            <MudText Typo="Typo.caption">@UiText.ForwarderMsiUploadConfirmIntro</MudText>
            <MudText Typo="Typo.caption" Class="mt-1">@string.Format(UiText.ForwarderMsiUploadConfirmFileNameFormat, _stagedUpload.FinalFileName)</MudText>
            <MudText Typo="Typo.caption">@string.Format(UiText.ForwarderKitMsiDetectedVersionFormat, _stagedUpload.ProductVersion)</MudText>
            <MudText Typo="Typo.caption">@string.Format(UiText.ForwarderKitMsiSha256Format, _stagedUpload.Sha256)</MudText>
            <MudText Typo="Typo.caption">@StagedOfficialHashMatchText()</MudText>

            @if (_stagedUpload.ExistingFileName is not null)
            {
                <MudText Color="Color.Warning" role="alert" Class="mt-2">@UiText.ForwarderMsiUploadReplaceWarningTitle</MudText>
                <MudText Typo="Typo.caption">@string.Format(UiText.ForwarderMsiUploadReplaceOldSha256Format, _stagedUpload.ExistingSha256)</MudText>
                <MudText Typo="Typo.caption">@string.Format(UiText.ForwarderMsiUploadReplaceNewSha256Format, _stagedUpload.Sha256)</MudText>
                <YaguraCheckboxField Label="@UiText.ForwarderMsiUploadReplaceAcknowledge" @bind-Value="_replaceAcknowledged" />
            }

            @if (!IsStagedOfficialHashMatch())
            {
                <MudText Color="Color.Warning" role="alert" Class="mt-2">@UiText.ForwarderMsiUploadHashMismatchWarning</MudText>
                <YaguraCheckboxField Label="@UiText.ForwarderMsiUploadHashMismatchAcknowledge" @bind-Value="_uploadVersionMismatchAcknowledged" />
            }

            <div class="mt-2">
                <YaguraButton Role="YaguraButtonRole.Normal" OnClick="CommitUploadAsync">@UiText.ForwarderMsiUploadCommitButton</YaguraButton>
                <YaguraButton Role="YaguraButtonRole.Normal" OnClick="CancelUploadAsync">@UiText.ForwarderMsiUploadCancelButton</YaguraButton>
            </div>
        }
    }
</MudPaper>

<MudPaper Elevation="1" Class="pa-4 mt-4">
    @if (_errorText is not null)
    {
        <MudText Class="mb-2" Color="Color.Error" role="alert">@_errorText</MudText>
    }
    <YaguraButton Role="YaguraButtonRole.Primary" OnClick="GenerateAsync">@UiText.ForwarderKitGenerateButton</YaguraButton>
</MudPaper>

@code {
    private enum DestinationMode
    {
        None,
        Candidate,
        Manual,
    }

    private IReadOnlyList<NicCandidate> _candidates = [];
    private DestinationMode _selectedMode = DestinationMode.None;
    private string? _selectedAddress;
    private string? _manualHost;
    private string _portText = ForwarderKitConstraints.DefaultPort.ToString(System.Globalization.CultureInfo.InvariantCulture);
    private ForwarderKitMode _selectedForwardMode = ForwarderKitMode.Udp;
    private bool _channelSystem = true;
    private bool _channelApplication = true;
    private bool _channelSecurity;
    private string? _errorText;

    // ---- MSI オプトイン同梱（ADR-0008 設計条件 9・ADR-0009 決定7・委任 #4） ----
    private ForwarderMsiArchitecture _selectedArchitecture = ForwarderMsiArchitecture.Win64;
    private ForwarderMsiLookup? _msiLookup;
    private bool _includeMsi;
    private bool _versionMismatchAcknowledged;
    private string? _effectiveVersion;
    private bool _versionMismatch;

    // ---- MSI アップロード（ADR-0020。配置経路 (b)。Issue #283） ----
    private ForwarderMsiWriteAccess? _writeAccess;
    private ElementReference _fileInput;
    private IJSObjectReference? _uploadModule;
    private bool _uploadInProgress;
    private string? _uploadError;
    private string? _uploadNotice;
    private StagedUploadInfo? _stagedUpload;
    private bool _replaceAcknowledged;
    private bool _uploadVersionMismatchAcknowledged;
    private bool _deleteConfirming;
    private bool _deleteAcknowledged;

    protected override void OnInitialized()
    {
        _candidates = NicCandidateSource.GetCandidates();
        RefreshMsiLookup();

        if (UploadOptions.Enabled)
        {
            // 書き込み可否の実挙動検出（ADR-0020 決定 2・委任 2）。画面表示のたびに 1 回——
            // 周期の ACL 監視（1033/1034）とは別に、利用者が今まさに操作できるかを実書き込み
            // プローブで確かめる（頻度が低いため SACL 汚染の懸念は周期監視と異なり許容）。
            _writeAccess = MsiStore.CheckWriteAccess();
        }
    }

    /// <summary>
    /// 選択中のアーキテクチャで <see cref="IForwarderMsiSource.Lookup(ForwarderMsiArchitecture)"/>
    /// を呼び直す（ADR-0009 決定7・委任 #4。<see cref="Lookup(ForwarderMsiArchitecture)"/> は
    /// 指定アーキの MSI のみを候補とするため、アーキを切り替えるたびに検出結果も切り替わる）。
    /// </summary>
    private void RefreshMsiLookup()
    {
        _msiLookup = MsiSource.Lookup(_selectedArchitecture);
        _effectiveVersion = null;
        _versionMismatch = false;

        if (_msiLookup.State == ForwarderMsiLookupState.Single)
        {
            var details = _msiLookup.Details!;
            _effectiveVersion = ForwarderMsiFilter.ResolveEffectiveVersion(details.ProductVersion, details.FileName);
            _versionMismatch = !ForwarderMsiFilter.MatchesVerifiedVersion(_effectiveVersion, ForwarderKitConstraints.VerifiedFluentBitVersion);
        }
    }

    private void SelectArchitecture(ForwarderMsiArchitecture architecture)
    {
        _selectedArchitecture = architecture;
        // アーキを切り替えたら、前のアーキの検出結果に基づく選択状態を持ち越さない
        // （別アーキの MSI を誤って同梱要求してしまう事故を防ぐ）。
        _includeMsi = false;
        _versionMismatchAcknowledged = false;
        RefreshMsiLookup();
    }

    private string OfficialHashMatchText()
    {
        var details = _msiLookup!.Details!;
        var result = ForwarderMsiFilter.MatchesOfficialHash(details.Sha256, ForwarderMsiConstraints.GetOfficialSha256(_selectedArchitecture));
        return result switch
        {
            OfficialHashMatchResult.Match => UiText.ForwarderKitMsiOfficialHashMatch,
            OfficialHashMatchResult.Mismatch => UiText.ForwarderKitMsiOfficialHashMismatch,
            _ => UiText.ForwarderKitMsiOfficialHashUnverified,
        };
    }

    private void SelectCandidate(string address)
    {
        _selectedMode = DestinationMode.Candidate;
        _selectedAddress = address;
    }

    private void SelectManual()
    {
        _selectedMode = DestinationMode.Manual;
    }

    /// <summary>
    /// 転送方式を切り替える（Issue #156）。UDP・TCP はいずれも既定ポート 514 のため、ポート欄の
    /// 追従は不要（TLS 送信はキットから除外済み——オーナー決定 2026-07-11。security.md §6.1）。
    /// </summary>
    private void SelectForwardMode(ForwarderKitMode mode)
    {
        _selectedForwardMode = mode;
    }

    private void GenerateAsync()
    {
        _errorText = null;

        var host = _selectedMode switch
        {
            DestinationMode.Candidate => _selectedAddress,
            DestinationMode.Manual => _manualHost?.Trim(),
            _ => null,
        };

        if (string.IsNullOrWhiteSpace(host))
        {
            _errorText = UiText.ForwarderKitErrorDestinationRequired;
            return;
        }

        if (!ForwarderKitConstraints.HostRegex.IsMatch(host))
        {
            _errorText = UiText.ForwarderKitErrorDestinationInvalid;
            return;
        }

        if (!int.TryParse(_portText, out var port) ||
            port < ForwarderKitConstraints.MinPort || port > ForwarderKitConstraints.MaxPort)
        {
            _errorText = UiText.ForwarderKitErrorPortRange;
            return;
        }

        var channels = SelectedChannels();
        if (channels.Count == 0)
        {
            _errorText = UiText.ForwarderKitErrorChannelsRequired;
            return;
        }

        if (_includeMsi && _versionMismatch && !_versionMismatchAcknowledged)
        {
            _errorText = UiText.ForwarderKitErrorMsiVersionMismatchNotAcknowledged;
            return;
        }

        var query = BuildDownloadQuery(
            host, port, channels, _selectedArchitecture,
            _includeMsi, _versionMismatch, _versionMismatchAcknowledged, _selectedForwardMode);
        Navigation.NavigateTo($"/admin/forwarder-kit/download?{query}", forceLoad: true);
    }

    /// <summary>
    /// ダウンロードエンドポイントへ渡すクエリ文字列を組み立てる（テスト固定のため static に分離）。
    /// </summary>
    /// <remarks>
    /// <b>msiVersionMismatchAcknowledged の付与は回帰防止の対象</b>: 本パラメータは以前この画面の
    /// URL 組み立てに含まれておらず、版不一致時に画面の確認チェックを入れてもサーバ側
    /// （<c>ForwarderKitRequest.TryCreate</c> の最終防御）で常に「未確認」扱いになり 400 で
    /// 生成に失敗していた（PR #222 レビューで確認された既存不具合。同 PR で修正）。
    /// <c>ForwarderKitScreenDownloadQueryTests</c> が本メソッドの出力を固定する。
    /// </remarks>
    internal static string BuildDownloadQuery(
        string host,
        int port,
        IReadOnlyList<string> channels,
        ForwarderMsiArchitecture architecture,
        bool includeMsi,
        bool versionMismatch,
        bool versionMismatchAcknowledged,
        ForwarderKitMode mode = ForwarderKitMode.Udp)
    {
        var architectureValue = architecture == ForwarderMsiArchitecture.WinArm64 ? "arm64" : "x64";
        var query = $"host={Uri.EscapeDataString(host)}&port={port}&channels={Uri.EscapeDataString(string.Join(",", channels))}" +
                    $"&includeMsi={(includeMsi ? "true" : "false")}&architecture={architectureValue}";

        if (includeMsi && versionMismatch)
        {
            query += $"&msiVersionMismatchAcknowledged={(versionMismatchAcknowledged ? "true" : "false")}";
        }

        // 既定（udp）は mode パラメータ導入前と同じクエリ文字列を保つ——後方互換
        // （ForwarderKitScreenDownloadQueryTests の既存スナップショットを崩さない）。
        if (mode != ForwarderKitMode.Udp)
        {
            var modeValue = "tcp";
            query += $"&mode={modeValue}";
        }

        return query;
    }

    private List<string> SelectedChannels()
    {
        var channels = new List<string>();
        if (_channelSystem)
        {
            channels.Add("System");
        }

        if (_channelApplication)
        {
            channels.Add("Application");
        }

        if (_channelSecurity)
        {
            channels.Add("Security");
        }

        return channels;
    }

    // ---- MSI アップロード（ADR-0020 決定 3）: stage（JS fetch → 専用エンドポイント）→
    //      確認 → commit（circuit → IForwarderMsiPlacementService）の二段階 ----

    /// <summary>
    /// stage 応答（サーバが計算した検証結果）。JS interop の JSON（camelCase）から復元する。
    /// </summary>
    private sealed record StagedUploadInfo(
        string? Error,
        string? StagingToken,
        string? FinalFileName,
        string? ProductVersion,
        string? Sha256,
        long Length,
        string? OfficialHashMatch,
        bool VersionMismatch,
        string? ExistingFileName,
        string? ExistingSha256);

    private sealed record UploadPrecheckResult(bool Ok, string? Error, long? Size);

    private sealed record UploadStageEnvelope(int Status, bool Ok, StagedUploadInfo? Body);

    private async Task<IJSObjectReference> GetUploadModuleAsync() =>
        _uploadModule ??= await JS.InvokeAsync<IJSObjectReference>(
            "import", "./_content/Yagura.Web/js/forwarder-msi-upload.js");

    private async Task UploadAsync()
    {
        _uploadError = null;
        _uploadNotice = null;

        var module = await GetUploadModuleAsync();

        // 送信前のクライアント側サイズ検査（ADR-0020 決定 3——超過はサーバへ送らずに分かる）。
        var precheck = await module.InvokeAsync<UploadPrecheckResult>(
            "precheck", _fileInput, ForwarderMsiUploadConstraints.MaxUploadBytes);
        if (!precheck.Ok)
        {
            _uploadError = precheck.Error == "no-file"
                ? UiText.ForwarderMsiUploadNoFileSelected
                : string.Format(
                    UiText.ForwarderMsiUploadFileTooLargeFormat,
                    ForwarderMsiUploadConstraints.MaxUploadBytes / (1024 * 1024));
            return;
        }

        _uploadInProgress = true;
        try
        {
            var envelope = await module.InvokeAsync<UploadStageEnvelope>(
                "stage", _fileInput, ArchitectureQueryValue());

            if (!envelope.Ok || envelope.Body?.StagingToken is null)
            {
                _uploadError = MapStageError(envelope.Body?.Error, envelope.Status);
                return;
            }

            _stagedUpload = envelope.Body;
            _replaceAcknowledged = false;
            _uploadVersionMismatchAcknowledged = false;
        }
        finally
        {
            _uploadInProgress = false;
        }
    }

    private async Task CommitUploadAsync()
    {
        if (_stagedUpload?.StagingToken is null)
        {
            return;
        }

        _uploadError = null;

        // クライアント側の早期検証（サーバ側——store.Commit——の最終防御と同じ条件）。
        if (!IsStagedOfficialHashMatch() && !_uploadVersionMismatchAcknowledged)
        {
            _uploadError = UiText.ForwarderMsiUploadErrorNotAcknowledged;
            return;
        }

        if (_stagedUpload.ExistingFileName is not null && !_replaceAcknowledged)
        {
            _uploadError = UiText.ForwarderMsiUploadErrorNotAcknowledged;
            return;
        }

        var result = await PlacementService.CommitAsync(
            _stagedUpload.StagingToken,
            _uploadVersionMismatchAcknowledged,
            _replaceAcknowledged,
            _selectedArchitecture,
            await ResolveOperatorContextAsync());

        if (!result.Success)
        {
            _uploadError = result.Error switch
            {
                ForwarderMsiCommitError.VersionMismatchNotAcknowledged => UiText.ForwarderMsiUploadErrorNotAcknowledged,
                ForwarderMsiCommitError.ReplaceNotAcknowledged => UiText.ForwarderMsiUploadErrorNotAcknowledged,
                ForwarderMsiCommitError.FolderStateChanged => UiText.ForwarderMsiUploadErrorStateChanged,
                ForwarderMsiCommitError.WriteFailed => UiText.ForwarderMsiUploadErrorWriteFailed,
                _ => UiText.ForwarderMsiUploadErrorGeneric,
            };
            if (result.Error is ForwarderMsiCommitError.UnknownStagingToken or ForwarderMsiCommitError.FolderStateChanged)
            {
                _stagedUpload = null;
            }

            return;
        }

        _stagedUpload = null;
        _uploadNotice = UiText.ForwarderMsiUploadCommitted;
        // 配置の確定で検出結果が変わる——同梱チェックの持ち越しもリセットする（アーキ切替と同じ判断）。
        _includeMsi = false;
        _versionMismatchAcknowledged = false;
        RefreshMsiLookup();
    }

    private async Task CancelUploadAsync()
    {
        if (_stagedUpload?.StagingToken is null)
        {
            return;
        }

        await PlacementService.DiscardAsync(
            _stagedUpload.StagingToken, _selectedArchitecture, await ResolveOperatorContextAsync());
        _stagedUpload = null;
    }

    private void BeginDelete()
    {
        _deleteConfirming = true;
        _deleteAcknowledged = false;
        _uploadNotice = null;
        _uploadError = null;
    }

    private void CancelDelete()
    {
        _deleteConfirming = false;
        _deleteAcknowledged = false;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_msiLookup?.State != ForwarderMsiLookupState.Single)
        {
            return;
        }

        if (!_deleteAcknowledged)
        {
            _uploadError = UiText.ForwarderMsiUploadErrorNotAcknowledged;
            return;
        }

        var result = await PlacementService.DeleteAsync(
            _selectedArchitecture, _msiLookup.Details!.Sha256, await ResolveOperatorContextAsync());

        if (!result.Success)
        {
            _uploadError = result.Error switch
            {
                ForwarderMsiDeleteError.Sha256Mismatch => UiText.ForwarderMsiDeleteErrorMismatch,
                ForwarderMsiDeleteError.MultipleExistingFiles => UiText.ForwarderMsiUploadErrorMultipleExisting,
                ForwarderMsiDeleteError.WriteFailed => UiText.ForwarderMsiUploadErrorWriteFailed,
                _ => UiText.ForwarderMsiUploadErrorGeneric,
            };
        }
        else
        {
            _uploadNotice = UiText.ForwarderMsiDeleted;
            _includeMsi = false;
            _versionMismatchAcknowledged = false;
        }

        _deleteConfirming = false;
        _deleteAcknowledged = false;
        RefreshMsiLookup();
    }

    private async Task<ForwarderMsiOperatorContext> ResolveOperatorContextAsync()
    {
        var (scheme, principal) = AuditActorResolver.Resolve(
            (await AuthStateProvider.GetAuthenticationStateAsync()).User);
        return new ForwarderMsiOperatorContext(
            CircuitContext.RemoteAddress, CircuitContext.IsLoopbackListener, scheme, principal);
    }

    private string ArchitectureQueryValue() =>
        _selectedArchitecture == ForwarderMsiArchitecture.WinArm64 ? "arm64" : "x64";

    private bool IsStagedOfficialHashMatch() =>
        string.Equals(_stagedUpload?.OfficialHashMatch, nameof(OfficialHashMatchResult.Match), StringComparison.OrdinalIgnoreCase);

    private string StagedOfficialHashMatchText() => _stagedUpload?.OfficialHashMatch switch
    {
        nameof(OfficialHashMatchResult.Match) => UiText.ForwarderKitMsiOfficialHashMatch,
        nameof(OfficialHashMatchResult.Mismatch) => UiText.ForwarderKitMsiOfficialHashMismatch,
        _ => UiText.ForwarderKitMsiOfficialHashUnverified,
    };

    private static string MapStageError(string? error, int status) => error switch
    {
        "another-upload-in-progress" => UiText.ForwarderMsiUploadErrorBusy,
        "declared-length-exceeds-limit" or "stream-exceeds-limit" => UiText.ForwarderMsiUploadErrorTooLarge,
        "insufficient-disk-space" => UiText.ForwarderMsiUploadErrorDiskSpace,
        "write-failed" => UiText.ForwarderMsiUploadErrorWriteFailed,
        "product-version-unreadable" or "product-version-invalid" => UiText.ForwarderMsiUploadErrorVersionUnreadable,
        "multiple-existing-files" => UiText.ForwarderMsiUploadErrorMultipleExisting,
        "no-file" => UiText.ForwarderMsiUploadNoFileSelected,
        _ => UiText.ForwarderMsiUploadErrorGeneric,
    };
}
