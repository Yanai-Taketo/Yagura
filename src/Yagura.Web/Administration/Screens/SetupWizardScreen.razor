@page "/admin/setup"
@namespace Yagura.Web.Administration.Screens
@layout AdminScreenLayout
@using Yagura.Abstractions.Administration
@using Yagura.Web.Administration
@using Yagura.Web.Circuits
@inject ISetupWizardService SetupWizard
@inject YaguraCircuitContext CircuitContext
@inject YaguraCircuitAuthenticationStateProvider AuthStateProvider

@*
    初期セットアップウィザードの骨格（configuration.md §3〜§7・ui.md §4。M8-4。Issue #71）。

    - 進行状態はサーバ側セッション（ISetupWizardService の実装 = Yagura.Host 管轄）に置き、
      circuit 喪失後の再入で確定済みステップから再開する（§7）。再開位置は明示する。
    - 適用は冪等トークンつき（§7 の一回性保証）。反映方式（§3）を適用前に表示する。
    - 書き込み系サービスの参照は本画面（Yagura.Web.Administration.Screens）に限る——
      閲覧側コンポーネントからの参照は ViewerComponentReferenceIsolationTests が検出する。

    Issue #248: ステップ移動を一方向固定にしない。
    - どのステップを表示するかは UI ローカル状態（_currentStep）——確定済みステップ・
      次に確定すべきステップ（snapshot.NextStep）へはステップヘッダーから任意に移動できる。
      表示の移動はサーバ側の確定状態を変えない（確定の取り消しではない——GoBackAsync は
      互換のため契約に残すが、本画面は呼ばない）。
    - 適用完了後も行き止まりにしない: 「設定を変更する」で BeginReconfigurationAsync により
      現在の設定値を種にウィザードを再開できる（適用にはあらためて確認の確定 = 新トークンが
      必要——§7 の一回性はトークンごとに保たれる）。
*@
<PageTitle>@UiText.AdminSetupWizardTitle - Yagura</PageTitle>

<MudText Typo="Typo.h5">@UiText.AdminSetupWizardTitle</MudText>

@if (_snapshot is null)
{
    <MudText>@UiText.AdminScreenAccessChecking</MudText>
}
else if (_snapshot.Applied || _applyResult is not null)
{
    <MudPaper Elevation="1" Class="pa-4 mt-4">
        <MudText>@_resultMessage</MudText>
        @if (_applyResult is { Outcome: WizardApplyOutcome.Applied or WizardApplyOutcome.AlreadyApplied })
        {
            <MudText Class="mt-2">@FormatEffect(_applyResult.RequiredEffect)</MudText>
        }
        @if (!string.IsNullOrEmpty(_errorText))
        {
            <MudText Class="mt-2">@_errorText</MudText>
        }
        <div class="mt-4">
            @* 適用後の再編集導線（Issue #248——適用完了を行き止まりにしない）。 *@
            <YaguraButton Role="YaguraButtonRole.Primary" OnClick="BeginReconfigurationAsync">@UiText.WizardBeginReconfiguration</YaguraButton>
        </div>
    </MudPaper>
}
else
{
    @if (_snapshot.ConfirmedSteps.Count > 0)
    {
        @* 再開位置の明示（configuration.md §7「黙って空フォームに戻さない」） *@
        <MudText Class="mt-2">@string.Format(UiText.WizardResumeNoticeFormat, StepTitle(_snapshot.NextStep))</MudText>
    }

    @* ステップヘッダー（Issue #248）: 確定済みステップ・次に確定すべきステップへは任意に
       移動できる。未到達のステップは無効表示（前が未確定のうちは飛べない——サービス側の
       ConfirmStepAsync の制約と同じ）。MudStepper は使わず素朴なボタン列にとどめる
       （依存部品の挙動を増やさない）。 *@
    <div class="mt-4 d-flex flex-wrap align-center" role="navigation" aria-label="セットアップのステップ">
        @foreach (var step in WizardStepOrder)
        {
            <MudButton Variant="Variant.Text"
                       Color="@(step == _currentStep ? Color.Primary : Color.Default)"
                       Disabled="@(!CanNavigateTo(step))"
                       OnClick="() => NavigateToStep(step)">@StepTitle(step)</MudButton>
        }
    </div>

    <MudPaper Elevation="1" Class="pa-4 mt-4">
        <MudText Typo="Typo.h6">@StepTitle(_currentStep)</MudText>

        @if (!string.IsNullOrEmpty(_errorText))
        {
            <MudText Class="mt-2">@_errorText</MudText>
        }

        @switch (_currentStep)
        {
            case SetupWizardStep.Reception:
                <YaguraTextField Label="UDP 受信ポート" Required="true" @bind-Value="_udpPort" />
                <YaguraTextField Label="TCP 受信ポート" Required="true" @bind-Value="_tcpPort" />
                break;
            case SetupWizardStep.ViewerAccess:
                <YaguraTextField Label="閲覧ポート" Required="true" @bind-Value="_viewerPort" />
                @* 公開範囲は 2 値（Lan / LocalhostOnly）のため自由入力ではなく選択式にする
                   （誤入力防止。Issue #241 由来のオーナー指摘）。 *@
                <div class="mt-2">
                    <MudText Typo="Typo.body2">公開範囲</MudText>
                    <MudRadioGroup T="string" @bind-Value="_publicAccess">
                        <MudRadio T="string" Value="@("Lan")" Color="Color.Primary">LAN に公開（同一ネットワークの端末から閲覧できる）</MudRadio>
                        <MudRadio T="string" Value="@("LocalhostOnly")" Color="Color.Primary">このサーバ自身のみ（localhost 限定）</MudRadio>
                    </MudRadioGroup>
                </div>
                <YaguraTextField Label="管理ポート" Required="true" @bind-Value="_adminPort" />
                break;
            case SetupWizardStep.Retention:
                <YaguraTextField Label="@($"{UiText.SetupStepRetentionTitle}（日数）")" Required="true" @bind-Value="_retentionDays" />
                break;
            case SetupWizardStep.Review:
                <MudText>これまでに確定した内容で設定ファイル（yagura.json）を生成します。</MudText>
                <MudSimpleTable Elevation="0" Dense="true" Class="mt-2">
                    <tbody>
                        @foreach (var pair in _snapshot.ConfirmedValues.OrderBy(p => p.Key, StringComparer.Ordinal))
                        {
                            <tr><td>@pair.Key</td><td>@pair.Value</td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
                break;
        }

        <div class="mt-4">
            @* 前ステップへ戻る導線（表示の移動——確定の取り消しではない。Issue #248）。 *@
            @if (_currentStep != WizardStepOrder[0])
            {
                <MudButton Variant="Variant.Text" OnClick="GoBack" Class="mr-2">@UiText.WizardBack</MudButton>
            }
            @if (_currentStep == SetupWizardStep.Review && _snapshot.ApplyIdempotencyToken is not null)
            {
                <YaguraButton Role="YaguraButtonRole.Primary" OnClick="ApplyAsync">@UiText.WizardApply</YaguraButton>
            }
            else
            {
                <YaguraButton Role="YaguraButtonRole.Primary" OnClick="ConfirmCurrentStepAsync">@UiText.WizardConfirmStep</YaguraButton>
            }
        </div>
    </MudPaper>
}

@code {
    /// <summary>
    /// ステップの表示順（サービス側 SetupWizardService.StepOrder と同一の並び。契約上の
    /// 列挙 SetupWizardStep の定義順に依存せず、画面側で明示する）。
    /// </summary>
    private static readonly SetupWizardStep[] WizardStepOrder =
    [
        SetupWizardStep.Reception,
        SetupWizardStep.ViewerAccess,
        SetupWizardStep.Retention,
        SetupWizardStep.Review,
    ];

    private SetupWizardSnapshot? _snapshot;
    private SetupWizardApplyResult? _applyResult;
    private string? _resultMessage;
    private string? _errorText;

    /// <summary>
    /// 現在表示中のステップ（UI ローカル状態。Issue #248）。サーバ側の確定状態
    /// （configuration.md §7 のサーバ側セッション）とは独立で、確定済みステップの間は
    /// 自由に行き来できる。初期値は snapshot.NextStep（再開位置）。
    /// </summary>
    private SetupWizardStep _currentStep = SetupWizardStep.Reception;

    private string? _udpPort = "514";
    private string? _tcpPort = "514";
    private string? _viewerPort = "8514";
    private string? _publicAccess = "Lan";
    private string? _adminPort = "8515";
    private string? _retentionDays = "30";

    protected override async Task OnInitializedAsync()
    {
        _snapshot = await SetupWizard.GetSnapshotAsync();
        _currentStep = _snapshot.NextStep;
        if (_snapshot.Applied)
        {
            _resultMessage = UiText.WizardApplied;
        }

        // 再開時（confirmed 済みステップがある）は確定済みの入力値をフォームへ復元する
        // （既定値の空フォームに戻さない。configuration.md §7 の趣旨。戻る導線とも一貫させる）。
        SyncFieldsFromSnapshot();
    }

    /// <summary>そのステップをステップヘッダーから表示できるか（確定済み or 次に確定すべきステップ）。</summary>
    private bool CanNavigateTo(SetupWizardStep step) =>
        _snapshot is not null && (_snapshot.ConfirmedSteps.Contains(step) || step == _snapshot.NextStep);

    /// <summary>表示ステップを移動する（サーバ側の確定状態は変えない）。</summary>
    private void NavigateToStep(SetupWizardStep step)
    {
        if (!CanNavigateTo(step))
        {
            return;
        }

        _currentStep = step;
        _errorText = null;
        // 移動先ステップの確定済み入力値をフォームへ復元して再編集できるようにする。
        SyncFieldsFromSnapshot();
    }

    /// <summary>
    /// 1 つ前のステップへ表示を移動する（確定の取り消しではない——サービスの GoBackAsync は
    /// 呼ばない。Issue #248）。
    /// </summary>
    private void GoBack()
    {
        var index = Array.IndexOf(WizardStepOrder, _currentStep);
        if (index <= 0)
        {
            return;
        }

        _currentStep = WizardStepOrder[index - 1];
        _errorText = null;
        SyncFieldsFromSnapshot();
    }

    /// <summary>
    /// 適用済みの設定の再編集を開始する（Issue #248）。全入力ステップが確定済みの状態で
    /// 再開するため、表示は確認ステップから（編集したいステップはヘッダーで選ぶ）。
    /// </summary>
    private async Task BeginReconfigurationAsync()
    {
        try
        {
            _errorText = null;
            _snapshot = await SetupWizard.BeginReconfigurationAsync();
            _applyResult = null;
            _resultMessage = null;
            _currentStep = SetupWizardStep.Review;
            SyncFieldsFromSnapshot();
        }
        catch (WizardValidationException ex)
        {
            _errorText = ex.Message;
        }
    }

    /// <summary>確定済みの入力値（サーバ側セッション）をフォームの各フィールドへ復元する。</summary>
    private void SyncFieldsFromSnapshot()
    {
        if (_snapshot is null)
        {
            return;
        }

        var values = _snapshot.ConfirmedValues;
        if (values.TryGetValue(SetupWizardValueKeys.UdpPort, out var udpPort)) { _udpPort = udpPort; }
        if (values.TryGetValue(SetupWizardValueKeys.TcpPort, out var tcpPort)) { _tcpPort = tcpPort; }
        if (values.TryGetValue(SetupWizardValueKeys.ViewerHttpPort, out var viewerPort)) { _viewerPort = viewerPort; }
        if (values.TryGetValue(SetupWizardValueKeys.ViewerPublicAccess, out var publicAccess)) { _publicAccess = publicAccess; }
        if (values.TryGetValue(SetupWizardValueKeys.AdminHttpPort, out var adminPort)) { _adminPort = adminPort; }
        if (values.TryGetValue(SetupWizardValueKeys.RetentionDays, out var retentionDays)) { _retentionDays = retentionDays; }
    }

    private static string StepTitle(SetupWizardStep step) => step switch
    {
        SetupWizardStep.Reception => UiText.SetupStepReceptionTitle,
        SetupWizardStep.ViewerAccess => UiText.SetupStepViewerAccessTitle,
        SetupWizardStep.Retention => UiText.SetupStepRetentionTitle,
        _ => UiText.SetupStepReviewTitle,
    };

    private static string FormatEffect(ConfigurationApplyEffect effect) => effect switch
    {
        ConfigurationApplyEffect.Immediate => UiText.ApplyEffectImmediate,
        ConfigurationApplyEffect.ListenerReconfiguration => UiText.ApplyEffectListenerReconfiguration,
        _ => UiText.ApplyEffectRestartRequired,
    };

    private async Task ConfirmCurrentStepAsync()
    {
        if (_snapshot is null)
        {
            return;
        }

        var values = _currentStep switch
        {
            SetupWizardStep.Reception => new Dictionary<string, string>
            {
                [SetupWizardValueKeys.UdpPort] = _udpPort ?? string.Empty,
                [SetupWizardValueKeys.TcpPort] = _tcpPort ?? string.Empty,
            },
            SetupWizardStep.ViewerAccess => new Dictionary<string, string>
            {
                [SetupWizardValueKeys.ViewerHttpPort] = _viewerPort ?? string.Empty,
                [SetupWizardValueKeys.ViewerPublicAccess] = _publicAccess ?? string.Empty,
                [SetupWizardValueKeys.AdminHttpPort] = _adminPort ?? string.Empty,
            },
            SetupWizardStep.Retention => new Dictionary<string, string>
            {
                [SetupWizardValueKeys.RetentionDays] = _retentionDays ?? string.Empty,
            },
            _ => new Dictionary<string, string>(),
        };

        try
        {
            _errorText = null;
            _snapshot = await SetupWizard.ConfirmStepAsync(_currentStep, values);
            // 確定に成功したら、次に確定すべきステップへ表示を進める（確定済みステップの
            // 再確定では、残りの未確定ステップ——通常は確認——へ進む）。
            _currentStep = _snapshot.NextStep;
            SyncFieldsFromSnapshot();
        }
        catch (WizardValidationException ex)
        {
            // 検証エラーは項目直下相当の文言表示（ui.md §3.1——色だけにしない）。
            _errorText = ex.Message;
        }
    }

    private async Task ApplyAsync()
    {
        if (_snapshot?.ApplyIdempotencyToken is not string token)
        {
            return;
        }

        // 「誰が」欄（ADR-0010 決定 6）: circuit の現在の認証状態から操作者の方式・利用者名を
        // 導出して監査へ渡す（未認証 = 既定の loopback 無認証では両方 null → 接続元のみ記録）。
        var (operatorScheme, operatorPrincipal) = AuditActorResolver.Resolve(
            (await AuthStateProvider.GetAuthenticationStateAsync()).User);
        _applyResult = await SetupWizard.ApplyAsync(token, CircuitContext.RemoteAddress, operatorScheme, operatorPrincipal);
        _resultMessage = _applyResult.Outcome switch
        {
            WizardApplyOutcome.Applied => UiText.WizardApplied,
            WizardApplyOutcome.AlreadyApplied => UiText.WizardAlreadyApplied,
            WizardApplyOutcome.Conflict => UiText.WizardConflict,
            _ => UiText.WizardInvalidToken,
        };

        if (_applyResult.Outcome is WizardApplyOutcome.Conflict or WizardApplyOutcome.InvalidToken)
        {
            // 再読み込み（確認ステップからのやり直し）のため最新スナップショットを取り直す。
            _snapshot = await SetupWizard.GetSnapshotAsync();
            _currentStep = _snapshot.NextStep;
        }
    }
}
