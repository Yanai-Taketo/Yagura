@page "/admin/auth-setup"
@namespace Yagura.Web.Administration.Screens
@layout AdminScreenLayout
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Http
@using Yagura.Abstractions.Administration
@using Yagura.Web.Administration
@using Yagura.Web.Circuits
@inject IAdminAuthenticationAdminService AuthAdminService
@inject YaguraCircuitContext CircuitContext
@inject YaguraCircuitAuthenticationStateProvider AuthStateProvider
@inject Yagura.Web.Components.Common.IYaguraNotifier Notifier
@inject IAntiforgery Antiforgery
@inject PersistentComponentState ApplicationState

@*
    管理 UI 認証の設定画面（ADR-0010 決定 1・3。Phase 1）。

    - Windows 統合認証（Negotiate）・Kerberos-only opt-in・アプリ独自認証の有効化を切り替える
    - 最初の管理者アカウント（ユーザー名/パスワード）を loopback 中に設定する
      （決定 3「物理到達性による信頼が既に効いている状態でオペレーターが対話的に設定する」）
    - loopback 認証 opt-in（決定 1）は fail-closed 不変条件をサービス層が検証し、
      違反時は WizardValidationException のメッセージをそのまま表示する
*@
<PageTitle>@UiText.AdminAuthSetupTitle - Yagura</PageTitle>

<MudText Typo="Typo.h5">@UiText.AdminAuthSetupTitle</MudText>

@if (_status is null)
{
    <MudText>@UiText.AdminScreenAccessChecking</MudText>
}
else
{
    <MudPaper Elevation="1" Class="pa-4 mt-4">
        <MudSwitch T="bool" @bind-Value="_windowsEnabled" Label="Windows 統合認証(Negotiate)を有効にする" Color="Color.Primary" />
        @if (_windowsEnabled)
        {
            <MudSwitch T="bool" @bind-Value="_kerberosOnly" Label="Kerberos-only モード(NTLM を拒否する)" Color="Color.Primary" Class="ml-8" />
        }

        <MudSwitch T="bool" @bind-Value="_appEnabled" Label="アプリ独自 ID/パスワード認証を有効にする" Color="Color.Primary" Class="mt-4" />

        <MudSwitch T="bool" @bind-Value="_requireForLoopback" Label="loopback アクセスにも認証を課す(opt-in)" Color="Color.Warning" Class="mt-4" />
        <MudText Typo="Typo.caption">
            既定は loopback 無認証のままです。有効にすると、認証手段が全滅した場合の復旧は
            設定ファイルの手編集(物理到達 + ACL を満たす者に限る)が最終手段になります。
        </MudText>
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-4 mt-4">
        <MudText Typo="Typo.h6">最初の管理者アカウント</MudText>
        @if (_status.HasAppAccount)
        {
            <MudText Class="mt-2">現在のユーザー名: @(_status.AppAccountUsername)(下記でパスワードのみ変更できます)</MudText>
        }
        else
        {
            <MudText Class="mt-2">アプリ独自認証を有効にする場合は、ユーザー名とパスワードを設定してください。</MudText>
        }

        <MudTextField T="string" Label="@UiText.AdminLoginUsernameLabel" @bind-Value="_newUsername" Class="mt-2" />
        <MudTextField T="string" Label="@UiText.AdminLoginPasswordLabel" InputType="InputType.Password" @bind-Value="_newPassword" Class="mt-2" />
    </MudPaper>

    @if (_errorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">@_errorMessage</MudAlert>
    }

    @* 実行中の無効化(二重送信ガード)と例外の受け皿は YaguraButton が内蔵する(Issue #372)。 *@
    <YaguraButton Role="YaguraButtonRole.Primary" Class="mt-4" OnClick="ApplyAsync">
        適用する
    </YaguraButton>

    @* 認証セッションの緊急全失効（ADR-0013 決定 2）。退職者・漏洩疑い時、または Windows 権限剥奪を
       即時反映したいときに、発行済みの全認証セッションを一括無効化する。世代番号バンプで実装され、
       実行者自身もログアウトされる（app 認証・Windows 再ログインは引き続き可能）。プレーンな HTML
       フォームで minimal API（antiforgery 検証）へ POST する（AdminLoginScreen と同じ作法）。 *@
    <MudPaper Elevation="1" Class="pa-4 mt-4">
        <MudText Typo="Typo.h6">認証セッションの緊急全失効</MudText>
        <MudText Typo="Typo.caption" Class="mt-2">
            発行済みの全ログインセッションを直ちに無効化します。退職者が出たとき・資格情報の漏洩が
            疑われるとき・Windows 側で管理者権限を剥奪した反映を待てないときに使います。実行すると、
            あなた自身を含む全員が次の操作でログイン画面へ戻されます。
        </MudText>
        @if (_antiforgeryToken is not null)
        {
            <form method="post" action="/admin/sessions/invalidate-all" class="mt-2">
                <input type="hidden" name="__RequestVerificationToken" value="@_antiforgeryToken" />
                <button type="submit">全セッションを今すぐ失効する</button>
            </form>
        }
    </MudPaper>

    @* 相互リンク（ADR-0012 決定 1）: リモートバインド有効化には認証必須という依存があり
       行き来が必ず発生するため、リモートアクセス設定への導線を置く（逆方向の導線は
       AdminRemoteAccessScreen 側にある）。 *@
    <div class="mt-4">
        <MudLink Href="/admin/remote-access">@UiText.AdminAuthSetupRemoteAccessLinkText</MudLink>
    </div>
}

@code {
    private AdminAuthenticationStatus? _status;
    private bool _windowsEnabled;
    private bool _kerberosOnly;
    private bool _appEnabled;
    private bool _requireForLoopback;
    private string _newUsername = string.Empty;
    private string _newPassword = string.Empty;
    private string? _errorMessage;

    /// <summary>PersistentComponentState のキー（prerender → 対話的描画のトークン持ち越し用）。</summary>
    private const string AntiforgeryTokenStateKey = "admin-auth-setup-antiforgery-token";

    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private string? _antiforgeryToken;
    private PersistingComponentStateSubscription _persistingSubscription;

    protected override async Task OnInitializedAsync()
    {
        // 緊急全失効フォームの antiforgery トークン。静的 SSR/prerender の HttpContext からのみ発行でき、
        // 対話的描画へは PersistentComponentState で持ち越す（AdminLoginScreen と同じ作法・理由）。
        if (ApplicationState.TryTakeFromJson<string>(AntiforgeryTokenStateKey, out var restoredToken))
        {
            _antiforgeryToken = restoredToken;
        }
        else if (HttpContext is not null)
        {
            _antiforgeryToken = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
            _persistingSubscription = ApplicationState.RegisterOnPersisting(() =>
            {
                ApplicationState.PersistAsJson(AntiforgeryTokenStateKey, _antiforgeryToken);
                return Task.CompletedTask;
            });
        }

        _status = await AuthAdminService.GetStatusAsync();
        ApplyStatusToFields(_status);
    }

    private void ApplyStatusToFields(AdminAuthenticationStatus status)
    {
        _windowsEnabled = status.WindowsAuthEnabled;
        _kerberosOnly = status.KerberosOnly;
        _appEnabled = status.AppAuthEnabled;
        _requireForLoopback = status.RequireForLoopback;
        _newUsername = status.AppAccountUsername ?? string.Empty;
    }

    private async Task ApplyAsync()
    {
        _errorMessage = null;

        try
        {
            // 「誰が」欄（ADR-0010 決定 6）: circuit の現在の認証状態から操作者を導出して監査へ渡す。
            var (operatorScheme, operatorPrincipal) = AuditActorResolver.Resolve(
                (await AuthStateProvider.GetAuthenticationStateAsync()).User);

            _status = await AuthAdminService.ConfigureAsync(
                _windowsEnabled,
                _kerberosOnly,
                _appEnabled,
                _requireForLoopback,
                string.IsNullOrWhiteSpace(_newPassword) ? null : _newUsername,
                string.IsNullOrWhiteSpace(_newPassword) ? null : _newPassword,
                CircuitContext.RemoteAddress,
                operatorScheme,
                operatorPrincipal);

            _newPassword = string.Empty;
            ApplyStatusToFields(_status);
            Notifier.NotifyOk("管理 UI 認証設定を保存しました。反映にはサービス再起動が必要です。");
        }
        catch (WizardValidationException ex)
        {
            _errorMessage = ex.Message;
        }
    }
}
