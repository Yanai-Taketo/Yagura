@page "/admin/promotion"
@namespace Yagura.Web.Administration.Screens
@layout AdminScreenLayout
@using Yagura.Abstractions.Administration
@using Yagura.Web.Administration
@using Yagura.Web.Circuits
@inject IPromotionWizardService PromotionWizard
@inject ILogMigrationService LogMigration
@inject YaguraCircuitContext CircuitContext
@inject YaguraCircuitAuthenticationStateProvider AuthStateProvider

@*
    本番昇格（SQLite → SQL Server）ウィザード（database.md §6.1・ui.md §4。M8-4 骨格 = Issue #71、
    接続組み立て・認証トグル・修復 SQL 提示の UX 完成 = PR #102）。

    - 準備（接続検証）と本番（切替実行）を分離する（§6.1。準備は何度でも中断・再開できる）
    - 接続は項目入力を既定とし、接続文字列はサーバ側で組み立てる。直接入力は上級者向けに併存
    - パスワードは入力方式によらずマスク付き専用欄からのみ入力し、サーバのメモリにのみ保持、
      無操作 15 分（CF-3 仮値）で破棄（configuration.md §5。パスワードは snapshot に含まれない
      ため、画面のローカル状態のみが入力経路——破棄後の再開では再入力を求める）
    - 検証失敗は原因分類ごとの案内 + 修復 SQL（表示のみ。サーバは実行しない——§5.2）
    - 切替の確定前に蓄積ログが参照できなくなる帰結を予告する（§6.1 の予告義務・文言は ui.md §5.4）
    - 切替実行は破壊的操作 = 確認ダイアログ必須（ui.md §3.1）+ 冪等トークン（configuration.md §7）
*@
<PageTitle>@UiText.AdminPromotionWizardTitle - Yagura</PageTitle>

<MudText Typo="Typo.h5">@UiText.AdminPromotionWizardTitle</MudText>

@if (_snapshot is null)
{
    <MudText>@UiText.AdminScreenAccessChecking</MudText>
}
else if (_snapshot.Executed || _applyResult is not null)
{
    <MudPaper Elevation="1" Class="pa-4 mt-4">
        <MudText>@_resultMessage</MudText>
        @if (_applyResult is { Outcome: WizardApplyOutcome.Applied or WizardApplyOutcome.AlreadyApplied })
        {
            <MudText Class="mt-2">@FormatEffect(_applyResult.RequiredEffect)</MudText>
        }
    </MudPaper>
}
else
{
    @* --- 準備フェーズ: 接続の設定と検証（database.md §6.1） --- *@
    <MudPaper Elevation="1" Class="pa-4 mt-4">
        <MudText Typo="Typo.h6">@UiText.PromotionValidateConnection</MudText>
        <MudText Class="mt-2">@UiText.PromotionCredentialHandlingNote</MudText>

        @if (_snapshot.CredentialReentryRequired)
        {
            <MudText Class="mt-2" role="alert">@UiText.PromotionCredentialReentryRequired</MudText>
        }

        @* 入力方式の切り替え（項目入力を既定・直接入力は上級者向け——database.md §6.1） *@
        <div class="mt-4 mb-4">
            <YaguraButton OnClick="() => SwitchInputMode(PromotionConnectionInputMode.Form)"
                          Disabled="@(_inputMode == PromotionConnectionInputMode.Form)">
                @UiText.PromotionInputModeForm
            </YaguraButton>
            <YaguraButton OnClick="() => SwitchInputMode(PromotionConnectionInputMode.Raw)"
                          Disabled="@(_inputMode == PromotionConnectionInputMode.Raw)">
                @UiText.PromotionInputModeRaw
            </YaguraButton>
        </div>

        @if (_inputMode == PromotionConnectionInputMode.Form)
        {
            <YaguraTextField Label="@UiText.PromotionServerNameLabel"
                             Required="true"
                             Placeholder="@UiText.PromotionServerNamePlaceholder"
                             @bind-Value="_serverName" />
            <YaguraTextField Label="@UiText.PromotionDatabaseNameLabel"
                             Required="true"
                             @bind-Value="_databaseName" />
            <YaguraSelectField Label="@UiText.PromotionAuthModeLabel"
                               Required="true"
                               AllowEmpty="false"
                               Options="AuthModeOptions"
                               Value="@AuthModeValue"
                               ValueChanged="OnAuthModeChanged" />

            @if (_authenticationMode == PromotionAuthenticationMode.WindowsIntegrated)
            {
                @* 接続に使うアカウントの明示（database.md §6.1——SQL Server 側にどの名前で
                   見えるかを推測させない） *@
                <MudText Typo="Typo.caption" Class="mb-4">
                    @string.Format(UiText.PromotionWindowsAccountNoteFormat, _snapshot.ServiceAccountName)
                </MudText>
            }
            else
            {
                <YaguraTextField Label="@UiText.PromotionUserNameLabel"
                                 Required="true"
                                 @bind-Value="_userName" />
                <YaguraTextField Label="@UiText.PromotionPasswordLabel"
                                 Required="true"
                                 Masked="true"
                                 HelpText="@UiText.PromotionPasswordHelp"
                                 @bind-Value="_password" />
            }

            <YaguraCheckboxField Label="@UiText.PromotionTrustServerCertificateLabel"
                                 HelpText="@UiText.PromotionTrustServerCertificateHelp"
                                 @bind-Value="_trustServerCertificate" />
        }
        else
        {
            <YaguraTextField Label="@UiText.PromotionConnectionStringLabel"
                             Required="true"
                             HelpText="@UiText.PromotionRawConnectionStringHelp"
                             @bind-Value="_rawConnectionString" />
            <YaguraTextField Label="@UiText.PromotionPasswordLabel"
                             Masked="true"
                             HelpText="@UiText.PromotionPasswordHelp"
                             @bind-Value="_password" />
        }

        @if (_connectionErrorText is not null)
        {
            <MudText Typo="Typo.caption" Color="Color.Error" role="alert">@_connectionErrorText</MudText>
        }

        <div class="mt-4">
            <YaguraButton Role="YaguraButtonRole.Primary" OnClick="ValidateAsync">@UiText.PromotionValidateConnection</YaguraButton>
        </div>

        @if (_validationResult is not null)
        {
            @if (_validationResult.Success)
            {
                <MudText Class="mt-2">@UiText.PromotionValidationSucceeded</MudText>
            }
            else
            {
                @* 原因分類ごとの次の一手（database.md §6.1。分類不能は生メッセージ + 汎用案内のみ） *@
                <MudText Class="mt-2" role="alert">@FailureGuidance(_validationResult)</MudText>
                <MudText Typo="Typo.caption" Class="mt-1">@_validationResult.Message</MudText>
                @if (_validationResult.RemediationSql is string remediationSql)
                {
                    <div class="mt-2">
                        <YaguraCopyBlock Label="@UiText.PromotionRemediationSqlLabel" Value="@remediationSql" />
                    </div>
                }
            }
        }
    </MudPaper>

    @* --- 旧・組み込み DB ファイルの処分の選択（database.md §6.1「残置しない」） --- *@
    <MudPaper Elevation="1" Class="pa-4 mt-4">
        <MudText Typo="Typo.h6">これまでに保存したログの扱い</MudText>
        <MudText Class="mt-2">@UiText.PromotionSwitchWarning</MudText>

        <div class="mt-4">
            <YaguraButton OnClick="ShowEvacuationInput"
                          Disabled="@_showEvacuationInput">
                @UiText.PromotionDisposalEvacuate
            </YaguraButton>
            <YaguraButton OnClick="() => ChooseDisposalAsync(OldDatabaseDisposal.Delete, null)"
                          Disabled="@(_snapshot.Disposal == OldDatabaseDisposal.Delete)">
                @UiText.PromotionDisposalDelete
            </YaguraButton>
        </div>

        @if (_showEvacuationInput)
        {
            @* 退避先の指定（database.md §6.1——退避の選択時は必須・選択内容とともに監査対象） *@
            <div class="mt-4">
                <YaguraTextField Label="@UiText.PromotionEvacuationDirectoryLabel"
                                 Required="true"
                                 Placeholder="@UiText.PromotionEvacuationDirectoryPlaceholder"
                                 ErrorText="@_disposalErrorText"
                                 @bind-Value="_evacuationDirectory" />
                <YaguraButton OnClick="() => ChooseDisposalAsync(OldDatabaseDisposal.Evacuate, _evacuationDirectory)">
                    @UiText.PromotionConfirmEvacuation
                </YaguraButton>
            </div>
        }

        @if (_snapshot.Disposal is OldDatabaseDisposal chosen)
        {
            <MudText Class="mt-2">
                選択中: @(chosen == OldDatabaseDisposal.Evacuate
                    ? $"{UiText.PromotionDisposalEvacuate}（{_snapshot.EvacuationDirectory}）"
                    : UiText.PromotionDisposalDelete)
            </MudText>
        }
    </MudPaper>

    @* --- 切替本番（すべての事前検証が通ってから実行できる） --- *@
    <MudPaper Elevation="1" Class="pa-4 mt-4">
        <YaguraButton Role="YaguraButtonRole.Destructive"
                      Disabled="@(!CanExecute)"
                      ConfirmTitle="@UiText.PromotionExecuteConfirmTitle"
                      ConfirmSummary="@UiText.PromotionSwitchWarning"
                      ConfirmActionLabel="@UiText.PromotionExecuteConfirmAction"
                      OnClick="ExecuteAsync">
            @UiText.PromotionExecute
        </YaguraButton>
    </MudPaper>
}

@* 蓄積ログの移行（database.md §6.2。DB-5。Issue #266）: 昇格 + 再起動の後にだけ現れる。
   移行中も受信は継続する（書き込みゲートのバッチ単位直列化——LogMigrationService 参照）。 *@
@if (_migrationStatus is { } migrationStatus && migrationStatus.Availability != LogMigrationAvailability.NotPromoted)
{
    <MudPaper Class="pa-4 mt-4">
        <MudText Typo="Typo.h6">@UiText.MigrationSectionTitle</MudText>

        @if (migrationStatus.Availability == LogMigrationAvailability.Completed)
        {
            <MudAlert Severity="Severity.Success" Class="mt-2">@UiText.MigrationAlreadyCompleted</MudAlert>
        }
        else if (migrationStatus.Availability == LogMigrationAvailability.Ready)
        {
            <MudText Typo="Typo.body2" Class="mt-2">@UiText.MigrationDescription</MudText>
            <MudText Typo="Typo.body2" Class="mt-1">
                対象: @($"{migrationStatus.SourceRecordCount:N0}") 件
                @if (migrationStatus.MigratedCount > 0)
                {
                    <text>（うち @($"{migrationStatus.MigratedCount:N0}") 件は移行済み——中断からの再開になります）</text>
                }
            </MudText>

            @if (_migrationRunning)
            {
                <MudProgressLinear Indeterminate="@(_migrationProgress is null)"
                                   Value="@(_migrationProgress is { } p && p.SourceRecordCount > 0 ? (double)p.MigratedCount / p.SourceRecordCount * 100 : 0)"
                                   Class="mt-2" />
                @if (_migrationProgress is { } running)
                {
                    <MudText Typo="Typo.body2">@string.Format(UiText.MigrationProgressFormat, running.MigratedCount, running.SourceRecordCount)</MudText>
                }
            }
            else
            {
                <div class="mt-2">
                    <YaguraButton Role="YaguraButtonRole.Primary" OnClick="RunMigrationAsync">
                        @UiText.MigrationExecute
                    </YaguraButton>
                </div>
            }
        }

        @if (_migrationResult is { } migrationResult)
        {
            <MudAlert Severity="@(migrationResult.Succeeded ? Severity.Success : Severity.Warning)" Class="mt-2">
                @migrationResult.Message
            </MudAlert>
        }
    </MudPaper>
}

@code {
    private const string AuthModeWindowsValue = "windows";
    private const string AuthModeSqlValue = "sql";

    private static readonly IReadOnlyList<YaguraSelectOption> AuthModeOptions =
    [
        new(AuthModeWindowsValue, UiText.PromotionAuthModeWindows),
        new(AuthModeSqlValue, UiText.PromotionAuthModeSql),
    ];

    private PromotionWizardSnapshot? _snapshot;
    private PromotionValidationResult? _validationResult;
    private PromotionApplyResult? _applyResult;
    private string? _resultMessage;
    private string? _connectionErrorText;
    private string? _disposalErrorText;

    // ---- 接続入力のローカル状態（snapshot から復元。パスワードだけは snapshot に含まれない
    //      ため常にこの画面のローカル状態が唯一の入力経路——configuration.md §5） ----
    private PromotionConnectionInputMode _inputMode = PromotionConnectionInputMode.Form;
    private string? _serverName;
    private string? _databaseName;
    private PromotionAuthenticationMode _authenticationMode = PromotionAuthenticationMode.WindowsIntegrated;
    private string? _userName;
    private bool _trustServerCertificate;
    private string? _password;
    private string? _rawConnectionString;

    // ---- 処分のローカル状態 ----
    private bool _showEvacuationInput;
    private string? _evacuationDirectory;

    private bool CanExecute =>
        _snapshot is { ConnectionValidated: true, Disposal: not null, ExecuteIdempotencyToken: not null };

    private string AuthModeValue =>
        _authenticationMode == PromotionAuthenticationMode.WindowsIntegrated ? AuthModeWindowsValue : AuthModeSqlValue;

    protected override async Task OnInitializedAsync()
    {
        _snapshot = await PromotionWizard.GetSnapshotAsync();
        _migrationStatus = await LogMigration.GetStatusAsync();
        if (_snapshot.Executed)
        {
            _resultMessage = UiText.WizardApplied;
        }

        // 進行状態の復元（configuration.md §5——確定済みの入力は再開時に打ち直させない）。
        _inputMode = _snapshot.InputMode;
        _rawConnectionString = _snapshot.RawConnectionString;
        if (_snapshot.Form is PromotionConnectionForm form)
        {
            _serverName = form.ServerName;
            _databaseName = form.DatabaseName;
            _authenticationMode = form.AuthenticationMode;
            _userName = form.UserName;
            _trustServerCertificate = form.TrustServerCertificate;
        }

        if (_snapshot.Disposal == OldDatabaseDisposal.Evacuate)
        {
            _showEvacuationInput = true;
            _evacuationDirectory = _snapshot.EvacuationDirectory;
        }
    }

    private static string FormatEffect(ConfigurationApplyEffect effect) => effect switch
    {
        ConfigurationApplyEffect.Immediate => UiText.ApplyEffectImmediate,
        ConfigurationApplyEffect.ListenerReconfiguration => UiText.ApplyEffectListenerReconfiguration,
        _ => UiText.ApplyEffectRestartRequired,
    };

    /// <summary>原因分類ごとの案内文言（database.md §6.1。文言は UiText——ui.md §7.1）。</summary>
    private static string FailureGuidance(PromotionValidationResult result) => result.FailureKind switch
    {
        PromotionConnectionFailureKind.CertificateNotTrusted => UiText.PromotionFailureCertificateGuidance,
        PromotionConnectionFailureKind.ServerUnreachable => UiText.PromotionFailureUnreachableGuidance,
        PromotionConnectionFailureKind.LoginFailed => UiText.PromotionFailureLoginGuidance,
        PromotionConnectionFailureKind.DatabaseNotFound => UiText.PromotionFailureDatabaseNotFoundGuidance,
        _ => UiText.PromotionFailureUnclassifiedGuidance,
    };

    private void SwitchInputMode(PromotionConnectionInputMode mode)
    {
        _inputMode = mode;
        _connectionErrorText = null;
        _validationResult = null;
    }

    private Task OnAuthModeChanged(string? value)
    {
        _authenticationMode = value == AuthModeSqlValue
            ? PromotionAuthenticationMode.SqlServer
            : PromotionAuthenticationMode.WindowsIntegrated;
        return Task.CompletedTask;
    }

    private async Task ValidateAsync()
    {
        try
        {
            _connectionErrorText = null;
            _validationResult = null;

            // 入力を都度設定してから検証する（無操作タイムアウトで破棄済みの場合も、この経路が
            // 再入力そのものになる）。パスワードはこの呼び出しの引数でのみ渡る（snapshot・画面
            // 表示に平文が現れる経路を作らない——configuration.md §5）。
            if (_inputMode == PromotionConnectionInputMode.Form)
            {
                var form = new PromotionConnectionForm(
                    _serverName?.Trim() ?? string.Empty,
                    _databaseName?.Trim() ?? string.Empty,
                    _authenticationMode,
                    string.IsNullOrWhiteSpace(_userName) ? null : _userName.Trim(),
                    _trustServerCertificate);
                _snapshot = await PromotionWizard.SetConnectionFormAsync(form, _password);
            }
            else
            {
                _snapshot = await PromotionWizard.SetRawConnectionStringAsync(
                    _rawConnectionString ?? string.Empty, _password);
            }

            var (validateScheme, validatePrincipal) = await ResolveOperatorAsync();
            _validationResult = await PromotionWizard.ValidateConnectionAsync(
                CircuitContext.RemoteAddress, validateScheme, validatePrincipal);
            _snapshot = await PromotionWizard.GetSnapshotAsync();
        }
        catch (WizardValidationException ex)
        {
            _connectionErrorText = ex.Message;
        }
    }

    private void ShowEvacuationInput()
    {
        _showEvacuationInput = true;
        _disposalErrorText = null;
    }

    private async Task ChooseDisposalAsync(OldDatabaseDisposal disposal, string? evacuationDirectory)
    {
        try
        {
            _disposalErrorText = null;
            _snapshot = await PromotionWizard.ChooseOldDatabaseDisposalAsync(disposal, evacuationDirectory);

            if (disposal == OldDatabaseDisposal.Delete)
            {
                _showEvacuationInput = false;
            }
        }
        catch (WizardValidationException ex)
        {
            _disposalErrorText = ex.Message;
        }
    }

    private async Task ExecuteAsync()
    {
        if (_snapshot?.ExecuteIdempotencyToken is not string token)
        {
            return;
        }

        var (operatorScheme, operatorPrincipal) = await ResolveOperatorAsync();
        _applyResult = await PromotionWizard.ExecuteAsync(token, CircuitContext.RemoteAddress, operatorScheme, operatorPrincipal);
        _resultMessage = _applyResult.Outcome switch
        {
            WizardApplyOutcome.Applied => _applyResult.Message,
            WizardApplyOutcome.AlreadyApplied => UiText.WizardAlreadyApplied,
            WizardApplyOutcome.Conflict => UiText.WizardConflict,
            _ => UiText.WizardInvalidToken,
        };

        if (_applyResult.Outcome is WizardApplyOutcome.Conflict or WizardApplyOutcome.InvalidToken)
        {
            _snapshot = await PromotionWizard.GetSnapshotAsync();
            _applyResult = null;
        }
    }

    /// <summary>
    /// 「誰が」欄（ADR-0010 決定 6）: circuit の現在の認証状態から操作者の方式・利用者名を導出する
    /// （未認証 = 既定の loopback 無認証では両方 null → 監査は接続元のみ記録）。
    /// </summary>
    private async Task<(string? Scheme, string? Principal)> ResolveOperatorAsync() =>
        AuditActorResolver.Resolve((await AuthStateProvider.GetAuthenticationStateAsync()).User);

    // ---- 蓄積ログの移行（database.md §6.2。DB-5。Issue #266）----

    private LogMigrationStatus? _migrationStatus;
    private LogMigrationProgress? _migrationProgress;
    private LogMigrationResult? _migrationResult;
    private bool _migrationRunning;

    private async Task RunMigrationAsync()
    {
        _migrationRunning = true;
        _migrationResult = null;
        try
        {
            var (scheme, principal) = await ResolveOperatorAsync();
            var progress = new Progress<LogMigrationProgress>(p =>
            {
                _migrationProgress = p;
                _ = InvokeAsync(StateHasChanged);
            });

            _migrationResult = await LogMigration.RunAsync(
                CircuitContext.RemoteAddress, scheme, principal, progress);
        }
        catch (InvalidOperationException ex)
        {
            _migrationResult = new LogMigrationResult(false, 0, 0, 0, ex.Message);
        }
        finally
        {
            _migrationRunning = false;
            _migrationProgress = null;
            _migrationStatus = await LogMigration.GetStatusAsync();
        }
    }
}
