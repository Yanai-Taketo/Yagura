@page "/admin"
@namespace Yagura.Web.Administration.Screens
@layout AdminScreenLayout
@using Yagura.Abstractions.Administration
@inject IConfigurationReloadService ReloadService
@inject IEmailNotificationAdminService EmailNotificationAdminService

@*
    設定トップ（ui.md §4 の画面構成「設定（ウィザード群）」の入口。M8-4 骨格）。
    管理リスナ帰属・ガードは AdminScreenLayout が担う。

    再起動待ちの設定変更の常設カード（Issue #286。2026-07-18 オーナー裁定）: 設定の
    再読み込み（CF-4 層1）が累積追跡する「反映にサービス再起動が要るキー」を、再読み込み
    操作の時点だけでなく管理面の入口に常設表示する。表示先は認証済み管理面のみ——閲覧面
    （/status 等）には出さない（裁定——管理系情報を閲覧面に露出しない）。プロセス内状態の
    ため再起動で自然に消える。
*@
<PageTitle>@UiText.AdminHomeTitle - Yagura</PageTitle>

<MudText Typo="Typo.h5">@UiText.AdminHomeTitle</MudText>

@if (_pendingRestartKeys.Count > 0)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        <MudText Typo="Typo.subtitle1"><b>@UiText.AdminPendingRestartCardTitle</b></MudText>
        <MudText Typo="Typo.body2">@UiText.AdminPendingRestartCardDescription</MudText>
        <ul class="mt-2">
            @foreach (var entry in _pendingRestartKeys)
            {
                <li>
                    <code>@entry.Key</code>
                    <MudText Typo="Typo.caption" Class="ml-2 d-inline">
                        @UiText.AdminPendingRestartDetectedAtLabel<YaguraTimestamp Value="entry.DetectedAt" />
                    </MudText>
                </li>
            }
        </ul>
    </MudAlert>
}

@* メール通知チャネルの健全性カード(ADR-0017 決定 5。Issue #386): 設定画面ではなく
   「日常動線」である管理面入口に常設する(#286 の再起動待ちカードと同じ置き場)。機能を
   有効にしている(有効にしたつもりを含む)間だけ表示し、未使用の環境にはノイズを出さない。 *@
@if (_emailStatus is { Enabled: true } emailStatus)
{
    <MudAlert Severity="@EmailHealthSeverity(emailStatus)" Class="mt-4">
        <MudText Typo="Typo.subtitle1"><b>@UiText.AdminEmailHealthCardTitle</b></MudText>
        @if (emailStatus.Health.DisabledByInvalidConfiguration)
        {
            <MudText Typo="Typo.body2">@UiText.EmailNotificationDisabledByInvalidConfiguration</MudText>
        }
        <MudText Typo="Typo.body2">
            @UiText.EmailNotificationHealthLastSuccess: @FormatTimestamp(emailStatus.Health.LastSuccessAt) ／
            @UiText.EmailNotificationHealthLastFailure: @(emailStatus.Health.LastFailureKind ?? UiText.EmailNotificationHealthNever) ／
            @UiText.EmailNotificationHealthDropped: @string.Format(UiText.EmailNotificationHealthCountFormat, emailStatus.Health.DroppedCount) ／
            @UiText.EmailNotificationHealthSuppressed: @string.Format(UiText.EmailNotificationHealthCountFormat, emailStatus.Health.SuppressedCount)
        </MudText>
        <MudText Typo="Typo.caption" Class="mt-1 d-block">@UiText.AdminEmailHealthCardDescription</MudText>
        <MudLink Href="/admin/email-notification" Typo="Typo.caption">@UiText.AdminEmailHealthCardDetailLink</MudLink>
    </MudAlert>
}

<MudPaper Elevation="1" Class="pa-4 mt-4">
    <MudNavMenu>
        <MudNavLink Href="/admin/setup">@UiText.AdminSetupWizardTitle</MudNavLink>
        <MudNavLink Href="/admin/promotion">@UiText.AdminPromotionWizardTitle</MudNavLink>
        <MudNavLink Href="/admin/circuits">@UiText.AdminCircuitsTitle</MudNavLink>
        <MudNavLink Href="/admin/forwarder-kit">@UiText.ForwarderKitTitle</MudNavLink>
        <MudNavLink Href="/admin/auth-setup">@UiText.AdminAuthSetupTitle</MudNavLink>
        <MudNavLink Href="/admin/remote-access">@UiText.AdminRemoteAccessTitle</MudNavLink>
        <MudNavLink Href="/admin/ingestion-tls">@UiText.IngestionTlsTitle</MudNavLink>
        <MudNavLink Href="/admin/email-notification">@UiText.EmailNotificationTitle</MudNavLink>
        <MudNavLink Href="/admin/source-silence">@UiText.SourceSilenceTitle</MudNavLink>
    </MudNavMenu>
</MudPaper>

@code {
    private IReadOnlyList<PendingRestartKey> _pendingRestartKeys = [];
    private EmailNotificationStatus? _emailStatus;

    protected override async Task OnInitializedAsync()
    {
        // スナップショット読み取りのみ（再読み込みは実行しない——状態を変更しない読み取り口）。
        _pendingRestartKeys = ReloadService.GetPendingRestartKeys();
        _emailStatus = await EmailNotificationAdminService.GetStatusAsync();
    }

    /// <summary>
    /// カードの色: 「有効にしたつもりで送られていない」（設定不正で無効化）と直近の失敗ありは
    /// 警告、それ以外は情報（常設表示の既定）。
    /// </summary>
    private static MudBlazor.Severity EmailHealthSeverity(EmailNotificationStatus status) =>
        status.Health.DisabledByInvalidConfiguration || status.Health.LastFailureKind is not null
            ? MudBlazor.Severity.Warning
            : MudBlazor.Severity.Info;

    private static string FormatTimestamp(DateTimeOffset? value) =>
        value is null ? UiText.EmailNotificationHealthNever : value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
}
