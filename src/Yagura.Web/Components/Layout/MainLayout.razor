@namespace Yagura.Web.Components.Layout
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Http
@using Yagura.Web.Administration
@inject IJSRuntime JSRuntime
@inject ILogStore LogStore
@inject IYaguraSystemStatusReader StatusReader
@inject Yagura.Web.Circuits.YaguraCircuitContext CircuitContext
@inject ViewerAuthenticationRuntimeOptions ViewerAuthOptions
@inject NavigationManager Navigation
@implements IAsyncDisposable

@*
    全画面共通の骨格（ui.md §4: 上部アプリバー + 左ナビゲーション + コンテンツ領域。
    骨格自体も共通コンポーネント——本レイアウトがその実体）。M8-1 の先行最小形
    （アプリバー + コンテンツ領域）に、M8-3 で左ナビゲーション（折りたたみ可）と
    全画面共通の状態帯（ui.md §5.1）を追加した。

    状態帯のデータ（健康状態の判定結果 + 全送信元合算の最終受信時刻）は共通骨格が
    定期更新する（更新間隔は UI-2 の仮値 10 秒——どの画面を開いていても「今」を映す）。
    判定自体はサーバ側観測性（Yagura.Host.Observability.SystemStatusReader）の管轄で、
    ここは表示のみを担う（ui.md §5.1 実装参照のとおり）。

    MudThemeProvider が YaguraTheme（ui.md §2 のトークン割当。Theming/YaguraTheme.cs）を
    CSS 変数として描画する。ObserveSystemDarkModeChange は false —— OS テーマ追従は
    既定で無効とし、利用者が「OS の設定に合わせる」を明示選択した場合のみ
    WatchSystemDarkModeAsync で追従する（ui.md §2.4「既定では手動選択を尊重する」）。
*@
<MudThemeProvider @ref="_themeProvider"
                  Theme="YaguraTheme.Instance"
                  IsDarkMode="_isDarkMode"
                  ObserveSystemDarkModeChange="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* 影はカード段（elevation 1）。3 段規約は ui.md §2.3。 *@
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       aria-label="ナビゲーションの開閉"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">Yagura</MudText>
        <MudSpacer />
        @*
            テーマ切替（ui.md §2.4）: ライト / ダーク / OS の設定に合わせる の 3 択。
            選択はブラウザの localStorage（端末ごと）に保存し、サーバへは書き込まない
            ——閲覧リスナは書き込みエンドポイントを持たない（ui.md §4 の不変条件）。
        *@
        <MudMenu Icon="@CurrentModeIcon" Color="Color.Inherit" AriaLabel="表示テーマの切替">
            <MudMenuItem Icon="@Icons.Material.Filled.LightMode"
                         OnClick="() => SelectModeAsync(YaguraThemeMode.Light)">ライト</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.DarkMode"
                         OnClick="() => SelectModeAsync(YaguraThemeMode.Dark)">ダーク</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.SettingsBrightness"
                         OnClick="() => SelectModeAsync(YaguraThemeMode.System)">OS の設定に合わせる</MudMenuItem>
        </MudMenu>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always">
        @* 左ナビゲーション（ui.md §4。画面一覧・折りたたみ可） *@
        <MudNavMenu aria-label="@UiText.NavAriaLabel">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">@UiText.NavDashboard</MudNavLink>
            <MudNavLink Href="/search" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Search">@UiText.NavSearch</MudNavLink>
            <MudNavLink Href="/status" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MonitorHeart">@UiText.NavStatus</MudNavLink>
            @*
                管理リンクは管理リスナ（loopback 専用ポート）経由の circuit でのみ出す
                （閲覧リスナには出さない——安全側。IsAdminListener が null＝判定不能・prerender 中も
                出さない。到達可否自体は AdminScreenLayout のガードが担保するが、閲覧リスナに
                管理導線を「見せない」ことでも不要な露出を避ける。2026-07-06 試用フィードバック
                「8515 で開いても設定・昇格への導線が無くて分かりにくい」への対応）。
            *@
            @if (CircuitContext.IsAdminListener == true)
            {
                <MudDivider Class="my-2" />
                @* 管理ホーム（/admin）と認証設定（/admin/auth-setup）への直接導線（Issue #248——
                   左ナビからユーザ追加（認証設定）へ到達できない行き止まりの解消）。/admin は
                   配下パス（/admin/setup 等）と誤 Active にならないよう Match=All。 *@
                <MudNavLink Href="/admin" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AdminPanelSettings">@UiText.AdminHomeTitle</MudNavLink>
                <MudNavLink Href="/admin/auth-setup" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Lock">@UiText.AdminAuthSetupTitle</MudNavLink>
                <MudNavLink Href="/admin/remote-access" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Https">@UiText.AdminRemoteAccessTitle</MudNavLink>
                <MudNavLink Href="/admin/setup" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Tune">@UiText.AdminSetupWizardTitle</MudNavLink>
                <MudNavLink Href="/admin/reload" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Refresh">@UiText.AdminReloadTitle</MudNavLink>
                <MudNavLink Href="/admin/promotion" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Storage">@UiText.AdminPromotionWizardTitle</MudNavLink>
                <MudNavLink Href="/admin/circuits" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Cable">@UiText.AdminCircuitsTitle</MudNavLink>
                <MudNavLink Href="/admin/forwarder-kit" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Archive">@UiText.ForwarderKitTitle</MudNavLink>
            }
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="pa-4">
        @*
            全画面共通の状態帯（ui.md §5.1「ダッシュボード最上部（および全画面の状態帯）」）。
            「稼働中」はポートの待ち受けを意味し、ログが現に届いていることは意味しないため、
            全送信元合算の最終受信時刻を併記し、送信元別の受信状況への導線を置く。
        *@
        <div class="mb-4">
            <YaguraStatusBand Status="@_bandStatus"
                              Summary="@_bandSummary"
                              LastReceivedAt="@_lastReceivedAt"
                              SourcesLinkHref="/#sources" />
        </div>
        @*
            閲覧認証（ADR-0010 Phase 4 決定 7）の circuit 層ガード。HTTP 層の ViewerPolicy が
            「circuit 確立までの経路」を守るのに対し、確立済み circuit 上の対話的ナビゲーション
            （HTTP 要求を発生させない——security.md §1 L-5 の覆域の限界）を本ガードで塞ぐ。ログ本体
            （@Body の検索結果・メッセージ）は未認証では描画しない。状態帯（上）の集約健康・最終受信
            時刻は @Body より機微度が低く、未認証で一瞬露出しても即リダイレクトで閉じる（HTTP 層の
            ViewerPolicy が通常経路を既に遮断済み——本ガードは対話ナビの多層防御）。
        *@
        @if (_viewerAccessSatisfied)
        {
            @Body
        }
        else
        {
            <MudText>@UiText.ViewerScreenRequiresAuthentication</MudText>
        }
    </MudMainContent>
</MudLayout>

@code {
    /// <summary>
    /// テーマ選択の保存キー（ブラウザの localStorage。端末ごと保存 = ui.md §2.4 の
    /// 「掲示用の大型モニタはダーク・手元 PC はライト」の使い分けと整合）。
    /// </summary>
    private const string StorageKey = "yagura.theme-mode";

    /// <summary>状態帯の更新間隔（UI-2 の仮値。ダッシュボードの更新間隔と同じ）。</summary>
    private static readonly TimeSpan BandUpdateInterval = TimeSpan.FromSeconds(10);

    /// <summary>最終受信時刻の取得（最新 1 件）のタイムアウト（内部クエリの防御値。仮値）。</summary>
    private static readonly TimeSpan LastReceivedQueryTimeout = TimeSpan.FromSeconds(5);

    private MudThemeProvider? _themeProvider;
    private YaguraThemeMode _mode = YaguraThemeMode.Light;
    private bool _isDarkMode;
    private bool _systemWatchRegistered;
    private bool _drawerOpen = true;

    private YaguraStatusKind _bandStatus = YaguraStatusKind.Ok;
    private string? _bandSummary;
    private DateTimeOffset? _lastReceivedAt;
    private PeriodicTimer? _bandTimer;
    private Task? _bandLoop;

    /// <summary>
    /// 閲覧認証（ADR-0010 Phase 4）の充足。既定 true——閲覧認証無効時・管理リスナ帰属時・ログイン画面では
    /// 常に @Body を描画する。閲覧認証有効かつ閲覧リスナ経由で未認証のときのみ false になる。
    /// </summary>
    private bool _viewerAccessSatisfied = true;

    /// <summary>
    /// HTTP 要求文脈（静的 SSR / prerender）でのみ供給されるカスケード値。対話的描画では null——
    /// その場合は circuit の帰属・汲み直し済み認証状態で判定する（AdminScreenLayout と同型）。
    /// </summary>
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    /// <summary>circuit の現在の認証状態（ADR-0010 決定 2。AddCascadingAuthenticationState が供給）。</summary>
    [CascadingParameter]
    public Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override async Task OnInitializedAsync()
    {
        // 初期表示（prerender を含む）で状態帯を組み立てる。以後は定期更新
        // （OnAfterRenderAsync で開始——prerender では動かない）。
        await RefreshStatusBandAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await EvaluateViewerAccessAsync();
    }

    /// <summary>
    /// 閲覧認証（ADR-0010 Phase 4 決定 7）の充足判定。閲覧認証有効・閲覧リスナ帰属・非ログイン画面のときのみ
    /// 管理 ⊇ 閲覧のセッション（<see cref="AdminAuthenticationExtensions.IsViewingAllowed"/>）を要求し、未充足なら
    /// 閲覧ログインへフルページ遷移する（AdminScreenLayout の認証充足判定と同型）。
    /// </summary>
    private async Task EvaluateViewerAccessAsync()
    {
        if (!ViewerAuthOptions.Enabled)
        {
            _viewerAccessSatisfied = true;
            return;
        }

        // ログイン画面自身は認可対象外（未認証で到達できなければならない——循環防止）。
        var isLoginRoute = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/') ==
            AdminAuthenticationExtensions.ViewerLoginPath.TrimEnd('/');
        if (isLoginRoute)
        {
            _viewerAccessSatisfied = true;
            return;
        }

        // 管理リスナの loopback 束縛面が「確実」なら本ガードの対象外（ローカル復旧/全アクセス経路——
        // ViewerPolicy の HTTP 判定と同じ根拠に揃える。リモート管理 HTTPS 面は閲覧セッションを要求する——
        // 田中・クリスのレビュー指摘）。帰属不明（null）は「確実な管理 loopback」ではないため gate 側へ倒す
        // （fail-closed——未認証で閲覧本体を露出させない）。SSR/prerender は接続の実ローカルポート、
        // 対話的描画は circuit 確立時の loopback 帰属で判定する（AdminScreenLayout の isLoopbackListener と同型）。
        var definitelyAdminLoopback = HttpContext is not null
            ? AdminAuthenticationExtensions.IsLoopbackAdminConnection(HttpContext)
            : CircuitContext.IsLoopbackListener == true;
        if (definitelyAdminLoopback)
        {
            _viewerAccessSatisfied = true;
            return;
        }

        // ここから先はガード対象。判定が確定するまで fail-closed に倒す——下の await が yield した瞬間の
        // 中間描画で @Body（ログ本体）を露出させない（circuit 再利用時の OnParametersSetAsync 再評価で、
        // 前回の充足値が残ったまま await 待ちの間に @Body が一瞬描画される leak を防ぐ）。
        _viewerAccessSatisfied = false;

        // 認証状態の取得元を _access と同じ根拠に揃える（AdminScreenLayout と同型）: SSR/prerender は
        // HttpContext.User を正とし、対話的描画は circuit の汲み直し済み認証状態を使う。
        var user = HttpContext?.User
            ?? (AuthenticationStateTask is null
                ? new System.Security.Claims.ClaimsPrincipal(new System.Security.Claims.ClaimsIdentity())
                : (await AuthenticationStateTask).User);

        _viewerAccessSatisfied = AdminAuthenticationExtensions.IsViewingAllowed(user);

        if (!_viewerAccessSatisfied)
        {
            // fail-closed: 未認証のまま閲覧本体（@Body）は描画しない。閲覧ログインへフルページ遷移する
            // （forceLoad: true——アンチフォージェリトークン/Cookie の対は HTTP 要求でのみ発行できるため。
            // AdminScreenLayout のログイン誘導と同じ理由）。
            Navigation.NavigateTo(AdminAuthenticationExtensions.ViewerLoginPath, forceLoad: true);
        }
    }

    private async Task RunBandLoopAsync(PeriodicTimer timer)
    {
        try
        {
            while (await timer.WaitForNextTickAsync())
            {
                await RefreshStatusBandAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // 破棄による停止。
        }
    }

    private async Task RefreshStatusBandAsync()
    {
        try
        {
            var status = StatusReader.ReadCurrent();
            _bandStatus = status.Health.Kind switch
            {
                YaguraHealthKind.Error => YaguraStatusKind.Error,
                YaguraHealthKind.Warning => YaguraStatusKind.Warning,
                _ => YaguraStatusKind.Ok,
            };
            _bandSummary = BuildSummary(status.Health);

            // 全送信元合算の最終受信時刻 = 最新 1 件の受信時刻（ui.md §5.1 の併記要件。
            // 「保存済みの最新」であり、スプール滞留分は反映が遅れ得る——観測できる範囲の値）。
            var latest = await LogStore.QueryLatestAsync(1, LastReceivedQueryTimeout);
            _lastReceivedAt = latest.Count > 0 ? latest[0].ReceivedAt : null;
        }
        catch (Exception)
        {
            // 状態帯の更新失敗で画面全体を壊さない——前回値を保持する（更新停止の警告は
            // ダッシュボード側の出し分けと YaguraStaleGuard が担う。ui.md §5.2）。
        }
    }

    /// <summary>判定理由 → 平易語サマリ（YaguraHealthReason と 1 対 1。ui.md §7）。</summary>
    private static string? BuildSummary(YaguraHealthReading health)
    {
        if (health.Reasons.Count == 0)
        {
            return null; // 正常時は YaguraStatusBand の既定文言（ui.md §5.1 の確定文言）に委ねる。
        }

        var parts = health.Reasons.Select(reason => reason switch
        {
            YaguraHealthReason.LossObserved => UiText.HealthReasonLoss,
            YaguraHealthReason.SpoolEvacuationObserved => UiText.HealthReasonSpoolEvacuation,
            YaguraHealthReason.SpoolUsageNearLimit => UiText.HealthReasonSpoolNearLimit,
            YaguraHealthReason.SpoolDegraded => UiText.HealthReasonSpoolDegraded,
            _ => reason.ToString(),
        });

        return string.Join("。", parts);
    }

    private string CurrentModeIcon => _mode switch
    {
        YaguraThemeMode.Dark => Icons.Material.Filled.DarkMode,
        YaguraThemeMode.System => Icons.Material.Filled.SettingsBrightness,
        _ => Icons.Material.Filled.LightMode,
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        // 状態帯の定期更新を開始する（対話モード確立後のみ——prerender では動かない）。
        _bandTimer = new PeriodicTimer(BandUpdateInterval);
        _bandLoop = RunBandLoopAsync(_bandTimer);

        // 保存済みの選択を復元する。prerender 中は JS 呼び出しが使えないため初回描画後に行う
        // （circuit 確立までの一瞬は既定のライトで表示される——既定がライトである以上、
        // ダーク保存端末での短時間の明転を v0.1 では許容する）。
        // localStorage は標準 API を IJSRuntime から直接呼ぶ——手書き JS ファイルは
        // 追加しない（ADR-0003 決定 1 の範囲内。分離 JS モジュールの例外手続きも不要）。
        YaguraThemeMode restored;
        try
        {
            var stored = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", StorageKey);
            restored = Enum.TryParse<YaguraThemeMode>(stored, ignoreCase: true, out var parsed)
                ? parsed
                : YaguraThemeMode.Light;
        }
        catch (JSException)
        {
            // localStorage が使えない環境（プライベートモードの一部等）では既定のライトで動作する。
            restored = YaguraThemeMode.Light;
        }

        await ApplyModeAsync(restored, persist: false);
    }

    private async Task SelectModeAsync(YaguraThemeMode mode)
    {
        await ApplyModeAsync(mode, persist: true);
    }

    private async Task ApplyModeAsync(YaguraThemeMode mode, bool persist)
    {
        _mode = mode;

        if (mode == YaguraThemeMode.System && _themeProvider is not null)
        {
            // OS 追従（UI-9 で「JS 手書きなしで可」を確認済み。ui.md §2.4）:
            // MudThemeProvider の同梱 JS（matchMedia("(prefers-color-scheme: dark)")）を使う。
            _isDarkMode = await _themeProvider.GetSystemDarkModeAsync();

            if (!_systemWatchRegistered)
            {
                await _themeProvider.WatchSystemDarkModeAsync(OnSystemDarkModeChangedAsync);
                _systemWatchRegistered = true;
            }
        }
        else
        {
            _isDarkMode = mode == YaguraThemeMode.Dark;
        }

        if (persist)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("localStorage.setItem", StorageKey, mode.ToString());
            }
            catch (JSException)
            {
                // 保存できなくても表示の切替自体は成立させる（次回訪問時に既定へ戻るだけ）。
            }
        }

        StateHasChanged();
    }

    private Task OnSystemDarkModeChangedAsync(bool isDarkMode)
    {
        // 手動選択尊重（ui.md §2.4）: OS 側の変化を反映するのは「OS の設定に合わせる」を
        // 選択中の場合のみ。ライト/ダーク手動選択中は勝手に切り替えない。
        if (_mode == YaguraThemeMode.System)
        {
            _isDarkMode = isDarkMode;
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        _bandTimer?.Dispose();

        if (_bandLoop is not null)
        {
            try
            {
                await _bandLoop;
            }
            catch (Exception)
            {
                // 破棄時の後片付け——更新ループの失敗はここでは伝播させない。
            }
        }
    }
}
