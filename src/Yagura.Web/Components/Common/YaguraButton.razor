@namespace Yagura.Web.Components.Common
@inject IDialogService DialogService
@inject IYaguraNotifier Notifier

@*
    ボタンの共通コンポーネント（ui.md §3.1 ボタン規約。M8-2）。

    - 主ボタン（Role=Primary。primary 塗り）は 1 ビューに 1 つまで——ビュー = 同時に視認
      される単位（ページ本体・ダイアログ・ウィザードの 1 ステップはそれぞれ別のビュー）。
      個数の制約は静的検査できないため、利用側画面のレビュー観点とする。
    - 破壊的操作（Role=Destructive）は state-error 系 + 確認ダイアログ必須。本コンポーネントが
      確認ダイアログの表示を内蔵し、確認なしで OnClick が呼ばれない構造にする。
    - クリック処理の実行中は自動で無効化する（二重送信ガード。Issue #372）。ハンドラから
      漏れた例外は state-error 通知に受け、circuit エラーにしない。
*@
<MudButton Variant="@Variant"
           Color="@Color"
           Class="@Class"
           Disabled="@(Disabled || _inFlight)"
           StartIcon="@StartIcon"
           ButtonType="@ButtonType"
           OnClick="HandleClickAsync">@ChildContent</MudButton>

@code {
    /// <summary>ボタンの役割（既定: 通常操作）。</summary>
    [Parameter]
    public YaguraButtonRole Role { get; set; } = YaguraButtonRole.Normal;

    /// <summary>ボタンの表示内容（文言）。</summary>
    [Parameter, EditorRequired]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// クリック時の処理。Role=Destructive の場合は確認ダイアログで確認された後にのみ呼ばれる。
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>ボタンに付与する追加 CSS クラス（余白調整等。トークン外の直書きはしない——ui.md §3.2）。</summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>先頭アイコン（任意。状態・エラーの伝達は色 + アイコンまたは文言で——ui.md §8）。</summary>
    [Parameter]
    public string? StartIcon { get; set; }

    /// <summary>HTML のボタン型（フォーム送信に使う場合は Submit）。</summary>
    [Parameter]
    public ButtonType ButtonType { get; set; } = ButtonType.Button;

    /// <summary>確認ダイアログの見出し（Role=Destructive で必須）。</summary>
    [Parameter]
    public string? ConfirmTitle { get; set; }

    /// <summary>確認ダイアログに出す「何が起きるかの要約」（Role=Destructive で必須。ui.md §3.1）。</summary>
    [Parameter]
    public string? ConfirmSummary { get; set; }

    /// <summary>確認ダイアログの確認ボタン文言（Role=Destructive で必須）。</summary>
    [Parameter]
    public string? ConfirmActionLabel { get; set; }

    private Variant Variant => Role switch
    {
        YaguraButtonRole.Primary => Variant.Filled,
        YaguraButtonRole.Destructive => Variant.Filled,
        _ => Variant.Outlined,
    };

    private Color Color => Role switch
    {
        YaguraButtonRole.Primary => Color.Primary,
        YaguraButtonRole.Destructive => Color.Error,
        _ => Color.Default,
    };

    protected override void OnParametersSet()
    {
        // 確認ダイアログ必須（ui.md §3.1）を構造で強制する: 破壊的操作なのに確認内容が
        // 与えられていない使い方は実装誤りとして即座に失敗させる。
        if (Role == YaguraButtonRole.Destructive &&
            (string.IsNullOrWhiteSpace(ConfirmTitle) ||
             string.IsNullOrWhiteSpace(ConfirmSummary) ||
             string.IsNullOrWhiteSpace(ConfirmActionLabel)))
        {
            throw new InvalidOperationException(
                "破壊的操作のボタン（Role=Destructive）には ConfirmTitle・ConfirmSummary・" +
                "ConfirmActionLabel が必須です（確認ダイアログ必須——ui.md §3.1 ボタン規約）。");
        }
    }

    private bool _inFlight;

    private async Task HandleClickAsync(MouseEventArgs args)
    {
        // 二重送信ガード（Issue #372）: Blazor Server は await 中に次のイベントを割り込ませる
        // ため、保存の await 中の再クリックが古い VersionToken のまま 2 回目の Save に到達し
        // 楽観競合になる。Disabled の再描画が届く前に発火済みのクリックはこの再入検査で捨てる
        // （画面上の Disabled 表示と二段構え）。
        if (_inFlight)
        {
            return;
        }

        _inFlight = true;
        try
        {
            if (Role == YaguraButtonRole.Destructive)
            {
                var confirmed = await YaguraConfirmDialog.ShowAsync(
                    DialogService, ConfirmTitle!, ConfirmSummary!, ConfirmActionLabel!, destructive: true);
                if (!confirmed)
                {
                    return;
                }
            }

            await OnClick.InvokeAsync(args);
        }
        catch (Exception ex)
        {
            // 例外の受け皿（Issue #372）: 第一の受け皿は各画面の catch（画面固有の文言・誘導）。
            // そこから漏れた例外（楽観競合・想定外の失敗）をここで受け、circuit エラーで画面全体が
            // 使えなくなる事態を防ぐ。state-error 通知は手動で閉じるまで残る（ui.md §3.1）。
            Notifier.NotifyError(string.Format(UiText.ButtonActionFailedFormat, ex.Message));
        }
        finally
        {
            _inFlight = false;
        }
    }
}
