@page "/"
@using System.Globalization
@inject ILogStore LogStore
@inject IYaguraSystemStatusReader StatusReader
@implements IAsyncDisposable

@*
    ダッシュボード（ui.md §4。M8-3。Issue #70。重大度分布・Top talkers = M8-5/Issue #159）:
    健康状態の一目確認（状態帯は全画面共通の骨格 = MainLayout 側に常設——ui.md §5.1
    「ダッシュボード最上部（および全画面の状態帯）」を共通骨格 1 箇所で満たし、二重表示を
    避ける）・受信量の推移・重大度分布（平常時からの逸脱検知）・受信量上位の送信元
    （Top talkers。フラッディング検知）・送信元別の受信状況（UI-4 無音化検出——最終受信時刻の
    古い順）・スプール/カウンタの現在値・保持期間の常時明示（database.md §3）。

    - 更新間隔は UI-2 の仮値（10 秒。重い集計——送信元別・受信量推移・重大度分布・
      Top talkers——は 60 秒ごと）
    - ステール警告（YaguraStaleGuard）を組み込み、circuit 生存中に更新だけが止まった局面の
      文言出し分け（ui.md §5.2 の確定文言）は本画面が引き受ける
    - データ取得はホスト側の既存読み取り口（ILogStore・IYaguraSystemStatusReader）のみ。
      受信量推移は既存の検索 API（QueryAsync）からの導出であり、取得上限で打ち切られた場合は
      その旨を注記する（導出の限界を隠さない）
    - **重大度分布・Top talkers の窓限定（Issue #145 への配慮）**: Severity・SourceAddress
      列には索引が無く（Issue #145 で追跡中）、無条件の集計は大規模時にフルスキャンへ
      劣化し得る。両集計は索引済みの ReceivedAt 範囲（直近 1 時間 = 受信量推移と同じ窓）
      へ必須で絞り込んでから集計する——索引追加そのものは Issue #145 の範囲であり、
      本画面はそれとは独立に「窓の必須化」で大規模時の劣化を抑える（ILogStore の
      QuerySeverityDistributionAsync / QueryTopTalkersAsync の doc コメント参照）
*@
<PageTitle>Yagura — @UiText.NavDashboard</PageTitle>

<div class="d-flex align-center flex-wrap gap-4 mb-4">
    <MudText Typo="Typo.h5">@UiText.NavDashboard</MudText>
    <MudSpacer />
    <YaguraStaleGuard @ref="_staleGuard" UpdateInterval="@UpdateInterval" />
    @if (_retentionDays is { } retentionDays)
    {
        <YaguraRetentionNotice RetentionDays="@retentionDays" />
    }
    else
    {
        <MudText Typo="Typo.caption" role="note">@UiText.RetentionDisabledNotice</MudText>
    }
</div>

@if (_updateStalled)
{
    <div class="mb-4">
        <YaguraSystemNotice Severity="YaguraNoticeSeverity.Warning"
                            Message="@UiText.StaleWhileConnectedNotice" />
    </div>
}

@if (_spoolEvacuationOngoing)
{
    @* 一時保管への退避中の常時表示（ui.md §5.4——色 + アイコン + 補足文言をセットで） *@
    <div class="mb-4">
        <YaguraSystemNotice Severity="YaguraNoticeSeverity.Warning"
                            Message="@UiText.SpoolEvacuationNotice" />
    </div>
}

<MudGrid Spacing="3" Class="mb-1">
    <MudItem xs="12" sm="6" md="3">
        <YaguraStatCard Label="@UiText.StatSpoolUsage" Value="@SpoolUsageValue" Supplement="@SpoolUsageSupplement" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <YaguraStatCard Label="@UiText.StatSpoolEvacuated" Value="@FormatCount(_spoolEvacuatedTotal)" Supplement="@SpoolEvacuatedSupplement" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <YaguraStatCard Label="@UiText.StatLossTotal" Value="@FormatCount(_lossTotal)" Supplement="@LossSupplement" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <YaguraStatCard Label="@UiText.StatStoredRecords" Value="@StoredRecordsValue" />
    </MudItem>
</MudGrid>
<div class="mb-4">
    <MudLink Href="/status" Typo="Typo.caption">@UiText.StatLinkToStatus</MudLink>
</div>

<div class="mb-4">
    <YaguraCard Title="@UiText.VolumeChartTitle">
        <YaguraTimelineChart RangeStart="@_chartRangeStart"
                             RangeEnd="@_chartRangeEnd"
                             Buckets="@_chartBuckets"
                             Outages="@_chartOutages" />
        @if (_volumeTruncatedCount is { } truncated)
        {
            <MudText Typo="Typo.caption" role="note">
                @string.Format(CultureInfo.InvariantCulture, UiText.VolumeChartTruncatedFormat, truncated)
            </MudText>
        }
    </YaguraCard>
</div>

<div class="mb-4">
    <MudGrid Spacing="3">
        <MudItem xs="12" md="5">
            <YaguraCard Title="@UiText.SeverityDistributionTitle">
                @if (_severityDistribution is null)
                {
                    <MudText Typo="Typo.body2">読み込み中です。</MudText>
                }
                else if (_severityDistribution.Count == 0)
                {
                    <MudText Typo="Typo.body2" role="note">@UiText.SeverityDistributionNoData</MudText>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var bucket in _severityDistribution)
                        {
                            <div class="d-flex align-center gap-2">
                                @if (bucket.Severity is { } severity)
                                {
                                    <YaguraSeverityChip Severity="@severity" />
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2">@UiText.SeverityDistributionUnparsedLabel</MudText>
                                }
                                <MudSpacer />
                                <MudText Typo="Typo.body2">@FormatCount(bucket.Count)</MudText>
                            </div>
                        }
                    </div>
                }
            </YaguraCard>
        </MudItem>
        <MudItem xs="12" md="7">
            <YaguraCard Title="@UiText.TopTalkersTitle">
                @if (_topTalkers is null)
                {
                    <MudText Typo="Typo.body2">読み込み中です。</MudText>
                }
                else if (_topTalkers.Count == 0)
                {
                    <MudText Typo="Typo.body2" role="note">@UiText.TopTalkersNoData</MudText>
                }
                else
                {
                    <YaguraTable TItem="SourceActivity" Items="@_topTalkers" RowsPerPage="@TopTalkersLimit">
                        <HeaderContent>
                            <MudTh>@UiText.SourceColumnAddress</MudTh>
                            <MudTh>@UiText.TopTalkersColumnCount</MudTh>
                            <MudTh>@UiText.SourceColumnActions</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="talker">
                            <MudTd DataLabel="@UiText.SourceColumnAddress"><YaguraSourceAddress Address="@talker.SourceAddress" /></MudTd>
                            <MudTd DataLabel="@UiText.TopTalkersColumnCount">@FormatCount(talker.RecordCount)</MudTd>
                            <MudTd DataLabel="@UiText.SourceColumnActions">
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Text"
                                           StartIcon="@Icons.Material.Filled.Search"
                                           Href="@SearchHrefFor(talker.SourceAddress)">@UiText.SourceSearchLinkLabel</MudButton>
                            </MudTd>
                        </RowTemplate>
                    </YaguraTable>
                }
            </YaguraCard>
        </MudItem>
    </MudGrid>
</div>

<div class="mb-4">
    @* 流量制限の発火上位送信元（Issue #288。案 (a) カード型——2026-07-18 オーナー裁定）:
       「取りこぼし（送信元ごとの受信量の制限）」の増加に気づいた運用者が「どの装置の暴走か」へ
       進むための view。UI-4（送信元別の受信状況）・Top talkers との住み分け（受信量 vs 制限発火の
       軸違い）と、値の生存期間（ゲートの有界バケットと同寿命）は説明文で明示する。
       データは流量制御ゲートの in-memory スナップショット（DB 非アクセス）のため軽い更新側。 *@
    <YaguraCard Title="@UiText.FlowControlRejectionsTitle">
        <MudText Typo="Typo.caption" role="note">@UiText.FlowControlRejectionsDescription</MudText>
        @if (_flowControlRejections.Count == 0)
        {
            <MudText Typo="Typo.body2" role="note" Class="mt-2">@UiText.FlowControlRejectionsNoData</MudText>
        }
        else
        {
            <YaguraTable TItem="YaguraFlowControlRejectionReading" Items="@_flowControlRejections" RowsPerPage="@FlowControlRejectionLimit">
                <HeaderContent>
                    <MudTh>@UiText.SourceColumnAddress</MudTh>
                    <MudTh>@UiText.FlowControlRejectionsColumnCount</MudTh>
                    <MudTh>@UiText.SourceColumnActions</MudTh>
                </HeaderContent>
                <RowTemplate Context="rejection">
                    <MudTd DataLabel="@UiText.SourceColumnAddress"><YaguraSourceAddress Address="@rejection.SourceAddress" /></MudTd>
                    <MudTd DataLabel="@UiText.FlowControlRejectionsColumnCount">@FormatCount(rejection.RejectedCount)</MudTd>
                    @* 発火送信元 → 当該送信元のログ調査への 1 クリック導線（Top talkers と同型）。 *@
                    <MudTd DataLabel="@UiText.SourceColumnActions">
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Text"
                                   StartIcon="@Icons.Material.Filled.Search"
                                   Href="@SearchHrefFor(rejection.SourceAddress)">@UiText.SourceSearchLinkLabel</MudButton>
                    </MudTd>
                </RowTemplate>
            </YaguraTable>
        }
    </YaguraCard>
</div>

<div id="sources" class="mb-4">
    <YaguraCard Title="@UiText.SourcesTitle">
        @if (_sources is null)
        {
            <MudText Typo="Typo.body2">読み込み中です。</MudText>
        }
        else if (_sources.Count == 0)
        {
            @* ログ未着の空状態: 受信先情報をコピーできる形で示す（ui.md §3.1 空状態規約） *@
            <YaguraEmptyState Title="@UiText.NoLogsEmptyTitle"
                              Description="@UiText.NoLogsEmptyNextAction">
                <NextAction>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var listener in _listeners)
                        {
                            <YaguraCopyField Label="@ListenerLabel(listener)"
                                             Value="@listener.Port.ToString(CultureInfo.InvariantCulture)" />
                        }
                    </div>
                </NextAction>
            </YaguraEmptyState>
        }
        else
        {
            <YaguraTable TItem="SourceActivity" Items="@_sources" RowsPerPage="20">
                <HeaderContent>
                    <MudTh>@UiText.SourceColumnAddress</MudTh>
                    <MudTh>@UiText.SourceColumnLastReceived</MudTh>
                    <MudTh>@UiText.SourceColumnSilence</MudTh>
                    <MudTh>@UiText.SourceColumnCount</MudTh>
                    <MudTh>@UiText.SourceColumnActions</MudTh>
                </HeaderContent>
                <RowTemplate Context="source">
                    @* 逆引きホスト名の併記(ADR-0007。ui.md §4)。ウォッチリスト登録済みの
                       送信元にはマークを付ける(ADR-0018 決定 4——登録は管理面の設定画面で行い、
                       閲覧面には導線を置かない。#286 の閲覧/管理分離)。 *@
                    <MudTd DataLabel="@UiText.SourceColumnAddress">
                        <YaguraSourceAddress Address="@source.SourceAddress" />
                        @if (FindWatch(source.SourceAddress) is { } watch)
                        {
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(watch.IsSilent ? Color.Error : Color.Info)"
                                     Class="ml-1">
                                @(watch.Label is null
                                    ? UiText.SourceWatchRegisteredChip
                                    : $"{UiText.SourceWatchRegisteredChip}: {watch.Label}")
                            </MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="@UiText.SourceColumnLastReceived"><YaguraTimestamp Value="@source.LastReceivedAt" /></MudTd>
                    <MudTd DataLabel="@UiText.SourceColumnSilence">
                        @FormatSilence(source.LastReceivedAt)
                        @if (FindWatch(source.SourceAddress) is { IsSilent: true })
                        {
                            @* 途絶中の強調(ADR-0018 決定 4)——判定は周期評価(1 分間隔)の結果 *@
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="ml-1">
                                @UiText.SourceWatchSilentChip
                            </MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="@UiText.SourceColumnCount">@FormatCount(source.RecordCount)</MudTd>
                    @* 無音化検出 → 当該送信元のログ調査への 1 クリック導線(ui.md §4。
                       リンク遷移のみでサーバ状態を変更しない = 閲覧面の不変条件の範囲内)。 *@
                    <MudTd DataLabel="@UiText.SourceColumnActions">
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Text"
                                   StartIcon="@Icons.Material.Filled.Search"
                                   Href="@SearchHrefFor(source.SourceAddress)">@UiText.SourceSearchLinkLabel</MudButton>
                    </MudTd>
                </RowTemplate>
            </YaguraTable>
            @if (_sources.Count >= SourceLimit)
            {
                <MudText Typo="Typo.caption" role="note">
                    @string.Format(CultureInfo.InvariantCulture, UiText.SourcesTruncatedFormat, _sources.Count)
                </MudText>
            }
        }
    </YaguraCard>
</div>

@code {
    // 更新間隔は UI-2 の仮値（ui.md §5.2——ステール閾値の基準もこの値。実利用で確定する）。
    private static readonly TimeSpan UpdateInterval = TimeSpan.FromSeconds(10);

    // 送信元別・受信量推移の再集計はライトな更新より低頻度にする（GROUP BY・範囲検索が
    // 保存先へ与える負荷を抑える——architecture.md §6 の資源分離の向き）。
    private const int HeavyRefreshEveryTicks = 6; // 10 秒 × 6 = 60 秒

    // 内部クエリの防御値（M-10 の検索仮値より短いタイムアウト——画面の定期更新が保存先を
    // 長時間占有しないため。仮値）。
    private static readonly TimeSpan InternalQueryTimeout = TimeSpan.FromSeconds(5);
    private static readonly TimeSpan ChartWindow = TimeSpan.FromMinutes(60);
    private static readonly TimeSpan ChartBucketWidth = TimeSpan.FromMinutes(5);
    private const int ChartQueryLimit = 10_000;
    private const int SourceLimit = 1_000;
    private const int OutageQueryLimit = 100;

    // 重大度分布・Top talkers の窓は受信量推移と同じ ChartWindow を使う（Issue #145 への
    // 配慮——索引済みの ReceivedAt 範囲へ絞り込んでから集計することでフルスキャンを避ける。
    // ILogStore.QuerySeverityDistributionAsync / QueryTopTalkersAsync の doc コメント参照）。
    private const int TopTalkersLimit = 10;

    // 流量制限の発火上位送信元（Issue #288）の表示件数（Top talkers と同じ上位 10）。
    private const int FlowControlRejectionLimit = 10;

    private YaguraStaleGuard? _staleGuard;
    private PeriodicTimer? _timer;
    private Task? _refreshLoop;

    private bool _updateStalled;
    private bool _spoolEvacuationOngoing;
    private int? _retentionDays;
    private IReadOnlyList<YaguraListenerEndpoint> _listeners = [];
    private long _spoolEvacuatedTotal;
    private long _lossTotal;
    // この画面を開いた時点の取りこぼし累計（進行中か過去かの見分け——UiText.StatLossTotalSupplementFormat）。
    // 対話 circuit ごとに新規インスタンスで null 初期化されるため、実質「開いてから」の基準になる。
    private long? _lossBaselineSinceOpen;
    private YaguraSpoolReading? _spool;
    private bool _spoolDegraded;
    private long? _storedRecords;

    private DateTimeOffset _chartRangeStart;
    private DateTimeOffset _chartRangeEnd;
    private IReadOnlyList<YaguraTimelineBucket> _chartBuckets = [];
    private IReadOnlyList<YaguraTimelineInterval> _chartOutages = [];
    private int? _volumeTruncatedCount;
    private IReadOnlyList<SourceActivity>? _sources;
    private IReadOnlyList<SeverityCount>? _severityDistribution;
    private IReadOnlyList<SourceActivity>? _topTalkers;
    private IReadOnlyList<YaguraFlowControlRejectionReading> _flowControlRejections = [];

    protected override async Task OnInitializedAsync()
    {
        // 初期表示（prerender を含む）で全セクションを一度組み立てる。
        var now = DateTimeOffset.UtcNow;
        RefreshLightSections(now);
        await RefreshHeavySectionsAsync(now);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        // 対話モード確立後の定期更新（prerender では動かない）。
        _timer = new PeriodicTimer(UpdateInterval);
        _refreshLoop = RunRefreshLoopAsync(_timer);
    }

    private async Task RunRefreshLoopAsync(PeriodicTimer timer)
    {
        var tick = 0;
        try
        {
            while (await timer.WaitForNextTickAsync())
            {
                tick++;
                try
                {
                    var now = DateTimeOffset.UtcNow;
                    RefreshLightSections(now);

                    if (tick % HeavyRefreshEveryTicks == 0)
                    {
                        await RefreshHeavySectionsAsync(now);
                    }

                    _updateStalled = false;

                    if (_staleGuard is not null)
                    {
                        await _staleGuard.NotifyUpdatedAsync(now);
                    }
                }
                catch (Exception)
                {
                    // circuit は生きているのに更新に失敗した局面（保存先障害・読み取り例外等）。
                    // 文言の出し分け（ui.md §5.2 の確定文言）は本画面の責務——警告を表示して
                    // 次の周期で再試行する（circuit 喪失時の警告は YaguraStaleGuard の
                    // クライアント側 JS が自律表示する）。
                    _updateStalled = true;
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Dispose による停止。
        }
    }

    /// <summary>軽い更新（同期の観測値のみ。毎周期）。</summary>
    private void RefreshLightSections(DateTimeOffset now)
    {
        var status = StatusReader.ReadCurrent();
        _retentionDays = status.RetentionDays;
        _listeners = status.Listeners;
        _spool = status.Spool;
        _spoolDegraded = status.SpoolDegraded;
        _spoolEvacuationOngoing = status.Health.Reasons.Contains(YaguraHealthReason.SpoolEvacuationObserved);
        _spoolEvacuatedTotal = status.Counters
            .Where(c => c.InstrumentName == "yagura.ingestion.spool.evacuated")
            .Sum(c => c.Value);
        // 「取りこぼし（累計）」は IsLoss な全カウンタの単純合計（Issue #201 まで単位は
        // 全種「件」で統一されていた）。Issue #201 で追加した「スプール末尾破損破棄」のみ
        // 単位がバイト（レコード単位では数えられないため。SystemStatusReader.
        // BuildCounterReadings のコメント参照）——本来なら異なる単位を同じ合計へ混ぜるべきでは
        // ないが、(a) この値が非ゼロになるのは torn write（クラッシュ・強制終了時の末尾破損）
        // 発生時のみで、1 回の発生量はフレーム 1 件分程度に収まる（実運用で「件」総数を
        // 大きく歪める規模にはならない）、(b) 代替（バイト単位を除外して合計する）は
        // architecture.md §3.1「カウンタに計上されない喪失は重大」の観測ギャップを閲覧面で
        // 再現することになり本末転倒、の 2 点から、単純合計へ含める判断とした（Issue #201
        // PR での明示の判断）。詳細な内訳確認（バイト値そのもの）は SystemStatus 画面の
        // カウンタ一覧（ラベルに「単位はバイト」と明記済み）で行う。
        _lossTotal = status.Counters.Where(c => c.IsLoss).Sum(c => c.Value);
        _lossBaselineSinceOpen ??= _lossTotal;

        // 流量制限の発火上位送信元（Issue #288）: ゲートの in-memory スナップショット
        // （DB 非アクセス）のため毎周期の軽い更新に含める。
        _flowControlRejections = StatusReader.ReadFlowControlRejections(FlowControlRejectionLimit);

        // 途絶検知のウォッチリスト状態（ADR-0018 決定 4。Issue #351）: 判定器の in-memory
        // スナップショット（DB 非アクセス）のため同じく軽い更新に含める。キーは正規化済み
        // アドレス（契約参照）。
        _sourceWatchByAddress = StatusReader.ReadSourceSilenceEntries()
            .ToDictionary(entry => entry.Address, StringComparer.OrdinalIgnoreCase);
    }

    /// <summary>重い更新（保存先への読み取り。初期表示 + 低頻度周期）。</summary>
    private async Task RefreshHeavySectionsAsync(DateTimeOffset now)
    {
        _chartRangeEnd = now;
        _chartRangeStart = now - ChartWindow;

        // 受信量推移: 既存の検索 API からの導出（軽量射影 1 文字 = 転送量の最小化。
        // 取得上限に達した場合は注記を出す——導出の限界を隠さない）。
        var records = await LogStore.QueryAsync(
            new LogQuery(
                Limit: ChartQueryLimit,
                Timeout: InternalQueryTimeout,
                ReceivedAtFrom: _chartRangeStart,
                ReceivedAtTo: _chartRangeEnd,
                MessageProjectionLength: 1));
        _volumeTruncatedCount = records.Count >= ChartQueryLimit ? records.Count : null;
        _chartBuckets = BuildBuckets(records, _chartRangeStart, _chartRangeEnd);

        // 受信断区間の重ね描き（architecture.md §4.4——ダッシュボードの時間軸にも出す）。
        var outages = await LogStore.QuerySystemEventsAsync(
            from: _chartRangeStart,
            to: _chartRangeEnd,
            limit: OutageQueryLimit,
            timeout: InternalQueryTimeout);
        _chartOutages = outages
            .Where(e => SystemEventKinds.IsDowntime(e.Kind))
            .Select(e => new YaguraTimelineInterval(e.StartAt, e.EndAt, e.Approximate))
            .ToList();

        // 送信元別の受信状況（UI-4 無音化検出——最終受信時刻の古い順。集計は provider 側）。
        _sources = await LogStore.QuerySourceActivityAsync(SourceLimit, InternalQueryTimeout);

        // 重大度分布（平常時からの逸脱検知）と Top talkers（受信量上位。フラッディング検知。
        // Issue #159）——いずれも受信量推移と同じ窓（直近 1 時間）に限定する（Issue #145 の
        // 索引欠如への配慮。ILogStore の doc コメント参照）。
        var severityDistribution = await LogStore.QuerySeverityDistributionAsync(
            _chartRangeStart, _chartRangeEnd, InternalQueryTimeout);
        _severityDistribution = OrderSeverityDistribution(severityDistribution);
        _topTalkers = await LogStore.QueryTopTalkersAsync(
            _chartRangeStart, _chartRangeEnd, TopTalkersLimit, InternalQueryTimeout);

        // 保存済み件数（統計契約。database.md §1.2 契約 6）。
        var statistics = await LogStore.GetStatisticsAsync();
        _storedRecords = statistics.RecordCount;
    }

    /// <summary>
    /// 重大度分布の表示順（severity 昇順。PRI が解析できなかった null バケットは末尾）。
    /// provider 側の GROUP BY は並び順を保証しないため、表示側で固定する。
    /// </summary>
    private static IReadOnlyList<SeverityCount> OrderSeverityDistribution(IReadOnlyList<SeverityCount> distribution) =>
        distribution
            .OrderBy(d => d.Severity ?? int.MaxValue)
            .ToList();

    private static IReadOnlyList<YaguraTimelineBucket> BuildBuckets(
        IReadOnlyList<LogRecordSummary> records,
        DateTimeOffset rangeStart,
        DateTimeOffset rangeEnd)
    {
        var bucketCount = (int)Math.Ceiling((rangeEnd - rangeStart) / ChartBucketWidth);
        var counts = new int[Math.Max(1, bucketCount)];

        foreach (var record in records)
        {
            var index = (int)((record.ReceivedAt - rangeStart) / ChartBucketWidth);
            if (index >= 0 && index < counts.Length)
            {
                counts[index]++;
            }
        }

        var buckets = new List<YaguraTimelineBucket>(counts.Length);
        for (var i = 0; i < counts.Length; i++)
        {
            var start = rangeStart + i * ChartBucketWidth;
            var end = i == counts.Length - 1 ? rangeEnd : start + ChartBucketWidth;
            buckets.Add(new YaguraTimelineBucket(start, end, counts[i]));
        }

        return buckets;
    }

    private string SpoolUsageValue => _spool is { } spool
        ? spool.UsageRatio.ToString("P0", CultureInfo.InvariantCulture)
        : UiText.StatSpoolUnavailable;

    private string? SpoolUsageSupplement => _spool is { } spool
        ? string.Create(CultureInfo.InvariantCulture, $"{FormatBytes(spool.CurrentUsageBytes)} / {FormatBytes(spool.QuotaBytes)}")
        : (_spoolDegraded ? UiText.HealthReasonSpoolDegraded : null);

    private string StoredRecordsValue => _storedRecords is { } records ? FormatCount(records) : "—";

    /// <summary>
    /// 取りこぼしカードの補足。取りこぼしが 0 のときは付けない（カードを静かに保つ）。
    /// 取りこぼしがある場合のみ「累計であること」と「開いてからの増分（進行中か過去かの手がかり）」を示す。
    /// </summary>
    private string? LossSupplement => _lossTotal > 0
        ? string.Format(CultureInfo.InvariantCulture, UiText.StatLossTotalSupplementFormat,
            FormatCount(_lossTotal - (_lossBaselineSinceOpen ?? _lossTotal)))
        : null;

    /// <summary>
    /// 一時保管への退避カードの補足（Issue #132）。累計が 0 のときは付けない（カードを静かに保つ）。
    /// 累計 &gt; 0 のときは「今も進行中か（<see cref="_spoolEvacuationOngoing"/>。消化完了の判定は
    /// <c>SystemStatusReader</c> がスプールの現在ゲージで行う）」で文言を出し分け、
    /// 「一度退避が発生すると画面表示が戻らない」という誤解（Issue #132 の報告）を防ぐ——
    /// 消化完了後は累計を過去分と分かる文言に切り替える。
    /// </summary>
    private string? SpoolEvacuatedSupplement => _spoolEvacuatedTotal switch
    {
        0 => null,
        _ when _spoolEvacuationOngoing => UiText.StatSpoolEvacuatedOngoingSupplement,
        _ => UiText.StatSpoolEvacuatedResolvedSupplement,
    };

    private static string ListenerLabel(YaguraListenerEndpoint listener) =>
        string.Format(CultureInfo.InvariantCulture, UiText.ListenerPortLabelFormat, listener.ProtocolName);

    private static string FormatCount(long value) => value.ToString("N0", CultureInfo.InvariantCulture);

    /// <summary>送信元を初期条件にしたログ検索への導線 URL（LogSearch 側の ?source= 受け取りと対）。</summary>
    private static string SearchHrefFor(string sourceAddress) =>
        "/search?source=" + Uri.EscapeDataString(sourceAddress);

    private static string FormatBytes(long bytes) => bytes switch
    {
        >= 1024L * 1024 * 1024 => string.Create(CultureInfo.InvariantCulture, $"{bytes / (1024.0 * 1024 * 1024):0.#} GB"),
        >= 1024L * 1024 => string.Create(CultureInfo.InvariantCulture, $"{bytes / (1024.0 * 1024):0.#} MB"),
        >= 1024L => string.Create(CultureInfo.InvariantCulture, $"{bytes / 1024.0:0.#} KB"),
        _ => string.Create(CultureInfo.InvariantCulture, $"{bytes} B"),
    };

    /// <summary>
    /// 途絶検知のウォッチリスト状態（正規化済みアドレスがキー。ADR-0018 決定 4）。
    /// 機能無効（ウォッチリスト未設定）の間は空。
    /// </summary>
    private Dictionary<string, YaguraSourceSilenceReading> _sourceWatchByAddress = new(StringComparer.OrdinalIgnoreCase);

    /// <summary>
    /// UI-4 の 1 行の送信元がウォッチリストに登録済みなら状態を返す（照合キーは登録側と同じ
    /// 正規化——IPv4-mapped IPv6 は IPv4 表記へ畳む）。
    /// </summary>
    private YaguraSourceSilenceReading? FindWatch(string sourceAddress)
    {
        if (_sourceWatchByAddress.Count == 0)
        {
            return null;
        }

        var key = System.Net.IPAddress.TryParse(sourceAddress, out var parsed)
            ? (parsed.IsIPv4MappedToIPv6 ? parsed.MapToIPv4() : parsed).ToString()
            : sourceAddress;

        return _sourceWatchByAddress.TryGetValue(key, out var watch) ? watch : null;
    }

    /// <summary>最後に受信してからの経過時間（無音時間）の表示。</summary>
    private static string FormatSilence(DateTimeOffset lastReceivedAt)
    {
        var elapsed = DateTimeOffset.UtcNow - lastReceivedAt;
        if (elapsed < TimeSpan.Zero)
        {
            elapsed = TimeSpan.Zero;
        }

        return elapsed switch
        {
            { TotalDays: >= 1 } => string.Create(CultureInfo.InvariantCulture, $"{(int)elapsed.TotalDays} 日 {elapsed.Hours} 時間"),
            { TotalHours: >= 1 } => string.Create(CultureInfo.InvariantCulture, $"{(int)elapsed.TotalHours} 時間 {elapsed.Minutes} 分"),
            { TotalMinutes: >= 1 } => string.Create(CultureInfo.InvariantCulture, $"{(int)elapsed.TotalMinutes} 分"),
            _ => "1 分未満",
        };
    }

    public async ValueTask DisposeAsync()
    {
        _timer?.Dispose();

        if (_refreshLoop is not null)
        {
            try
            {
                await _refreshLoop;
            }
            catch (Exception)
            {
                // 破棄時の後片付け——更新ループの失敗はここでは伝播させない。
            }
        }
    }
}
