@page "/search"
@using System.Globalization
@using Microsoft.AspNetCore.WebUtilities
@inject ILogStore LogStore
@inject IYaguraSystemStatusReader StatusReader
@inject NavigationManager Navigation

@*
    ログ検索（ui.md §4。M8-3。Issue #70）:
    - 絞り込みの強制はしない（architecture.md §6——条件なしで最新から閲覧できる。
      初期表示は条件なしの検索を自動実行する = イベントビューア相当の操作感）
    - 防御は出力の制限で行う: 結果上限 10,000 件・射影 200 文字・タイムアウト 30 秒
      （M-10 の仮値）+ 一覧のページング（YaguraTable 内蔵）
    - 受信断区間の時間軸表示（architecture.md §4.4）と保持地平の明示（database.md §2.3——
      保持期間より古い範囲は「削除済み」を明示し、その範囲の受信断区間は保持地平の明示と
      セットでのみ見せる。ui.md §5.3）
    - 詳細表示は個別取得（architecture.md §6「全文は詳細表示で個別取得する」——
      ILogStore.FindByIdAsync。M8-3 で追加した読み取り口）
    - 構造化データ（RFC 5424 STRUCTURED-DATA）は本文の前に原文のまま接頭表示する
      （オーナー承認済みデザイン。database.md §2.1・ui.md §4）。表示上の省略のみ
      （.yagura-sd-prefix。全文は詳細表示の構造化データ欄で見られる）——保存・解析は
      変更しない。SD を持たないレコード（RFC 3164 送信元等）では接頭表示自体を出さない
*@
<PageTitle>Yagura — @UiText.NavSearch</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">@UiText.NavSearch</MudText>

<div class="mb-4">
    <YaguraCard>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="4">
                <YaguraDateTimeField Label="@FromLabel" @bind-Value="_from" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <YaguraDateTimeField Label="@ToLabel" @bind-Value="_to" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <YaguraTextField Label="@UiText.SearchFieldSource" @bind-Value="_sourceAddress" />
            </MudItem>
            @* 重大度は完全一致ではなく閾値方式（Issue #148——「N 以上」の運用語彙を、選択値と、
               より深刻な値をすべて含む条件として表現する。補足は HelpText で明示する）。 *@
            <MudItem xs="12" sm="6" md="4">
                <YaguraSelectField Label="@UiText.SearchFieldSeverity"
                                   HelpText="@UiText.SearchFieldSeverityHelp"
                                   Options="@SeverityOptions"
                                   @bind-Value="_severityValue" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <YaguraSelectField Label="@UiText.SearchFieldFacility"
                                   Options="@FacilityOptions"
                                   @bind-Value="_facilityValue" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <YaguraSelectField Label="@UiText.SearchFieldParseStatus"
                                   Options="@ParseStatusOptions"
                                   @bind-Value="_parseStatusValue" />
            </MudItem>
            <MudItem xs="12" md="9">
                <YaguraTextField Label="@UiText.SearchFieldText" @bind-Value="_searchText" />
            </MudItem>
            @* 検索ボタンを隣の入力ボックス（本文の検索語）の下端に揃える。フォーム項目枠の
               下余白（yagura-form-field の mb-4 = 16px）の分だけ align-end の基準が下がるため、
               ボタン列に同じ 16px の下パディング（pb-4）を与えて押し上げる（2026-07-06 試用の
               「検索がずれて見える」フィードバック）。 *@
            <MudItem xs="12" md="3" Class="d-flex align-end pb-4">
                @* 主ボタンは 1 ビューに 1 つ（ui.md §3.1）——本画面ではこの検索ボタンのみ。
                   検索条件は URL クエリへ反映してから実行する（NavigateTo → OnParametersSetAsync
                   が実クエリを実行する単一経路。URL 共有・ブックマーク対応——Issue #148）。 *@
                <YaguraButton Role="YaguraButtonRole.Primary" OnClick="SubmitSearch" Disabled="@_searching">
                    @UiText.SearchButton
                </YaguraButton>
            </MudItem>
        </MudGrid>
    </YaguraCard>
</div>

@if (_retentionHorizon is { } horizon && SearchReachesBeyondHorizon(horizon))
{
    @* 保持地平の明示（database.md §2.3・ui.md §5.3）: 検索範囲が保持期間より古い場合。 *@
    <YaguraMissingDataNotice Kind="YaguraMissingDataKind.RetentionHorizon"
                             PeriodStart="@FromUtc"
                             PeriodEnd="@horizon" />
}

@if (_results is not null && _results.Count > 0)
{
    <div class="mt-4 mb-4">
        <YaguraCard>
            @* 受信断区間の時間軸表示（architecture.md §4.4——結果と同じ時間軸上に区間を重ねる） *@
            <YaguraTimelineChart RangeStart="@_chartRangeStart"
                                 RangeEnd="@_chartRangeEnd"
                                 Buckets="@_chartBuckets"
                                 Outages="@_chartOutages" />
        </YaguraCard>
    </div>

    @* CSV エクスポート導線（Issue #157）: 現在の検索条件を引き継いだまま
       /search/export.csv へ全ページ遷移する（ForwarderKitScreen の生成ボタンと同じ方式——
       NavigationManager.NavigateTo(url, forceLoad: true)。最終検証・件数上限はサーバ側の
       責務、ここは条件の引き渡しのみ）。クエリの組み立ては検索 URL（BuildSearchUrl）と
       同一の BuildQueryParameters を共有する——条件マッピングの二重管理を避け、
       「エクスポートは今見ている検索と同じ条件」を構造的に保証する（Issue #148 の
       URL 共有設計に相乗り）。主ボタン（検索）は上のフォームの 1 つのみのため、
       本ボタンは Normal ロールとする（ui.md §3.1「主ボタンは 1 ビューに 1 つ」）。 *@
    <div class="mb-4 d-flex align-center justify-end gap-2">
        <MudText Typo="Typo.caption" Class="yagura-detail-meta-label">
            @string.Format(CultureInfo.InvariantCulture, UiText.SearchExportCsvHintFormat, SearchLimit)
        </MudText>
        <YaguraButton Role="YaguraButtonRole.Normal" OnClick="ExportCsv">
            @UiText.SearchExportCsvButton
        </YaguraButton>
    </div>
}

@foreach (var outage in _visibleOutages)
{
    <YaguraMissingDataNotice Kind="@(outage.Approximate ? YaguraMissingDataKind.ReceptionOutageApproximate : YaguraMissingDataKind.ReceptionOutage)"
                             PeriodStart="@outage.StartAt"
                             PeriodEnd="@outage.EndAt" />
}

<div class="mt-4">
    @if (_results is null)
    {
        <MudText Typo="Typo.body2">読み込み中です。</MudText>
    }
    else if (_results.Count == 0)
    {
        @if (HasAnyCondition)
        {
            <YaguraEmptyState Title="@UiText.SearchNoResultsTitle"
                              NextAction="@NoResultsAction" />
        }
        else
        {
            @* 条件なしで 0 件 = まだ 1 件も受信していない（30 分動線の続き。ui.md §3.1 空状態） *@
            <YaguraEmptyState Title="@UiText.NoLogsEmptyTitle"
                              Description="@UiText.NoLogsEmptyNextAction">
                <NextAction>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var listener in _listeners)
                        {
                            <YaguraCopyField Label="@ListenerLabel(listener)"
                                             Value="@listener.Port.ToString(CultureInfo.InvariantCulture)" />
                        }
                    </div>
                </NextAction>
            </YaguraEmptyState>
        }
    }
    else
    {
        <YaguraTable TItem="LogRecordSummary"
                     Items="@_results"
                     OnRowSelected="ShowDetailAsync"
                     TruncatedAtLimit="@_hasMore">
            <HeaderContent>
                <MudTh>受信時刻</MudTh>
                <MudTh>@UiText.SourceColumnAddress</MudTh>
                <MudTh>重大度</MudTh>
                <MudTh>分類（ファシリティ）</MudTh>
                <MudTh>メッセージ</MudTh>
            </HeaderContent>
            <RowTemplate Context="record">
                <MudTd DataLabel="受信時刻"><YaguraTimestamp Value="@record.ReceivedAt" /></MudTd>
                @* 逆引きホスト名の併記(ADR-0007。共通コンポーネント YaguraSourceAddress——ui.md §4) *@
                <MudTd DataLabel="@UiText.SourceColumnAddress"><YaguraSourceAddress Address="@record.SourceAddress" /></MudTd>
                <MudTd DataLabel="重大度"><YaguraSeverityChip Severity="@record.Severity" /></MudTd>
                <MudTd DataLabel="分類（ファシリティ）">@UiText.FormatFacility(record.Facility)</MudTd>
                <MudTd DataLabel="メッセージ">
                    @if (record.StructuredData is { } structuredData)
                    {
                        <span class="yagura-monospace yagura-sd-prefix">@structuredData</span>
                    }
                    @SummaryMessage(record)
                </MudTd>
            </RowTemplate>
        </YaguraTable>
        @if (_hasMore)
        {
            @* カーソル（キーセット）ページングの追記型 UI（database.md DB-11。Issue #144 残課題）:
               現在の検索条件のまま、表示済み最後の行から続きを追加取得する。主ボタン（検索）は
               上部フォームの 1 つのみのため、本ボタンも Normal ロールとする（ui.md §3.1）。 *@
            <div class="mt-2 d-flex justify-center">
                <YaguraButton Role="YaguraButtonRole.Normal" OnClick="LoadMoreAsync" Disabled="@_loadingMore">
                    @(_loadingMore ? UiText.SearchLoadingMoreButton : UiText.SearchLoadMoreButton)
                </YaguraButton>
            </div>
        }
    }
</div>

@* 詳細はオーバーレイ(モーダルダイアログ)で表示する(2026-07-06 試用フィードバック——
   結果テーブルの下に開く方式は、行が多いと「押しても何も起きない」ように見えた。
   オーバーレイなら結果一覧の位置に関わらず必ず前面に出る)。inline の MudDialog を
   可視状態にバインドする方式(別ダイアログコンポーネント + レコード受け渡しを増やさない)。
   Esc・背景クリックで閉じる。角丸 8px はダイアログ面の共通スタイルが効く(ui.md §2.3)。 *@
<MudDialog @bind-Visible="_detailVisible" Options="_detailDialogOptions" Class="yagura-detail-dialog">
    <TitleContent>
        @* タイトルは色帯ヘッダーが兼ねる（重大度で色・アイコンが変わる。閉じるは帯の右端）。
           _detail が null（見つからない）のときは中立帯 + 見出しのみになる。 *@
        <YaguraSeverityBand Severity="@_detail?.Severity"
                            Facility="@_detail?.Facility"
                            OnClose="CloseDetail" />
    </TitleContent>
    <DialogContent>
        @if (_detail is null)
        {
            <MudText Typo="Typo.body2">@UiText.DetailNotFound</MudText>
        }
        else
        {
            @if (_detail.ParseStatus != ParseStatus.Parsed)
            {
                <div class="mb-3">
                    <YaguraSystemNotice Severity="YaguraNoticeSeverity.Info"
                                        Message="@(_detail.ParseStatus == ParseStatus.Incomplete ? UiText.IncompleteLabel : UiText.ParseFailedLabel)" />
                </div>
            }

            @* メッセージ本文を主役に（コピー付き）。 *@
            @if (_detail.Message is not null)
            {
                <YaguraCopyBlock Label="@UiText.DetailMessage" Value="@_detail.Message" />
            }

            @* メタ情報は 2 次情報として 2 列に整理（時刻・送信元など）。 *@
            <div class="yagura-detail-meta">
                <div>
                    <MudText Typo="Typo.caption" Class="yagura-detail-meta-label">@UiText.DetailReceivedAt</MudText>
                    <MudText Typo="Typo.body2"><YaguraTimestamp Value="@_detail.ReceivedAt" /></MudText>
                </div>
                <div>
                    <MudText Typo="Typo.caption" Class="yagura-detail-meta-label">@UiText.SourceColumnAddress</MudText>
                    @* 逆引きホスト名の併記(ADR-0007。ui.md §4) *@
                    <MudText Typo="Typo.body2"><YaguraSourceAddress Address="@_detail.SourceAddress" Port="@_detail.SourcePort" />（@_detail.Protocol）</MudText>
                </div>
                <div>
                    <MudText Typo="Typo.caption" Class="yagura-detail-meta-label">@UiText.DetailDeviceTimestamp</MudText>
                    <MudText Typo="Typo.body2">
                        @if (_detail.DeviceTimestamp is { } deviceTimestamp)
                        {
                            <YaguraTimestamp Value="@deviceTimestamp" />
                        }
                        else
                        {
                            @:—
                        }
                    </MudText>
                </div>
                <div>
                    @* 「(ログに記載)」で逆引きホスト名との由来の違いを明示する(ADR-0007 決定 1) *@
                    <MudText Typo="Typo.caption" Class="yagura-detail-meta-label">@UiText.DetailHostnameAppLabel</MudText>
                    <MudText Typo="Typo.body2">@(_detail.Hostname ?? "—") / @(_detail.AppName ?? "—")</MudText>
                </div>
            </div>

            @* 装置時計ずれの明示（ui.md §6・Issue #158）: 受信時刻との乖離が閾値以上の場合のみ
               注記する（BuildDeviceTimestampDriftNote が閾値判定込みで文言を組み立てる）。
               補足文言は RFC 3164（TZ 情報なし）由来の近似に触れる——出し分けの判断は同メソッドの
               コメントを参照。 *@
            @if (BuildDeviceTimestampDriftNote(_detail.ReceivedAt, _detail.DeviceTimestamp) is { } driftNote)
            {
                <div class="mb-3">
                    <YaguraSystemNotice Severity="YaguraNoticeSeverity.Info"
                                        Message="@driftNote"
                                        Supplement="@UiText.DetailDeviceTimestampDriftSupplement" />
                </div>
            }

            @if (_detail.StructuredData is not null)
            {
                <YaguraCopyBlock Label="@UiText.DetailStructuredData" Value="@_detail.StructuredData" Muted="true" />
            }
            @if (_detail.Raw is not null)
            {
                <YaguraCopyBlock Label="@UiText.DetailRaw" Value="@RawAsText(_detail.Raw)" Muted="true" />
            }
        }
    </DialogContent>
</MudDialog>

@code {
    // M-10 の仮値（architecture.md §6: 結果上限 10,000 件・射影 200 文字・タイムアウト 30 秒）。
    // internal: 「さらに読み込む」（database.md DB-11）の bUnit テストが、フェイクストアの
    // 応答件数をこの値に合わせるために参照する（DeviceTimestampDriftThreshold と同じ、
    // InternalsVisibleTo 経由でテストに公開する既存パターン）。
    internal const int SearchLimit = 10_000;
    private static readonly TimeSpan SearchTimeout = TimeSpan.FromSeconds(30);
    private static readonly TimeSpan DetailTimeout = TimeSpan.FromSeconds(5);
    private static readonly TimeSpan OutageQueryTimeout = TimeSpan.FromSeconds(5);
    private const int OutageQueryLimit = 100;
    private const int ChartBucketCount = 24;

    // ファシリティの選択肢（0〜23。RFC 5424 Table 1。UiText.FormatFacility と対応表を二重管理しない）。
    private const int FacilityOptionCount = 24;

    private static readonly IReadOnlyList<YaguraSelectOption> SeverityOptions =
        Enumerable.Range(0, UiText.SeverityOptionLabels.Count)
            .Select(i => new YaguraSelectOption(i.ToString(CultureInfo.InvariantCulture), UiText.SeverityOptionLabels[i]))
            .ToList();

    private static readonly IReadOnlyList<YaguraSelectOption> FacilityOptions =
        Enumerable.Range(0, FacilityOptionCount)
            .Select(i => new YaguraSelectOption(i.ToString(CultureInfo.InvariantCulture), UiText.FormatFacility(i)))
            .ToList();

    private static readonly IReadOnlyList<YaguraSelectOption> ParseStatusOptions =
    [
        new(nameof(ParseStatus.Parsed), UiText.ParseStatusOptionParsed),
        new(nameof(ParseStatus.ParseFailed), UiText.ParseStatusOptionParseFailed),
        new(nameof(ParseStatus.Incomplete), UiText.ParseStatusOptionIncomplete),
    ];

    private DateTime? _from;
    private DateTime? _to;
    private string? _sourceAddress;
    private string? _severityValue;
    private string? _facilityValue;
    private string? _parseStatusValue;
    private string? _searchText;
    private bool _searching;

    // カーソル（キーセット）ページングの「さらに読み込む」状態（database.md DB-11。Issue #144
    // 残課題）。_hasMore は直近の取得バッチがちょうど SearchLimit 件だったか（=まだ続きが
    // あり得るか）を表す——_results.Count 自体で判定すると、追記型で件数が増え続けるうちに
    // 「まだ続きがあるか」を表せなくなるため、直近バッチのみを見る専用フラグにする。
    // カーソルは URL に載せない（ui.md §4「カーソルページングの UI 判断」参照——検索条件のみを
    // URL の正とし、追記のページ位置は画面のローカル状態に留める）。
    private bool _hasMore;
    private bool _loadingMore;

    private IReadOnlyList<LogRecordSummary>? _results;
    private IReadOnlyList<SystemEvent> _visibleOutages = [];
    private DateTimeOffset _chartRangeStart;
    private DateTimeOffset _chartRangeEnd;
    private IReadOnlyList<YaguraTimelineBucket> _chartBuckets = [];
    private IReadOnlyList<YaguraTimelineInterval> _chartOutages = [];

    private LogRecord? _detail;

    private DateTimeOffset? _retentionHorizon;
    private IReadOnlyList<YaguraListenerEndpoint> _listeners = [];

    // ---- 検索条件 ⇔ URL クエリの双方向反映（Issue #148。URL 共有・ブックマーク対応） ----
    // SupplyParameterFromQuery: Router は同一ページ内でクエリだけが変わるナビゲーション
    // （NavigateTo）でもこれらのパラメータを再供給し、OnParametersSetAsync を再実行する
    // （.NET の標準機構。コンポーネントの再生成は起きない）。検索ボタン（SubmitSearch）は
    // NavigateTo で URL を書き換えるだけにし、実際のクエリ実行は OnParametersSetAsync に
    // 一本化する——NavigateTo → OnParametersSetAsync を唯一の実行経路にすることで二重実行を避ける。
    // ダッシュボードからの導線（?source=<アドレス>。ui.md §4）・ブラウザの戻る/進むも同じ経路を通る。

    [SupplyParameterFromQuery(Name = "from")]
    [Parameter]
    public string? FromQuery { get; set; }

    [SupplyParameterFromQuery(Name = "to")]
    [Parameter]
    public string? ToQuery { get; set; }

    [SupplyParameterFromQuery(Name = "source")]
    [Parameter]
    public string? SourceQuery { get; set; }

    [SupplyParameterFromQuery(Name = "severity")]
    [Parameter]
    public string? SeverityQuery { get; set; }

    [SupplyParameterFromQuery(Name = "facility")]
    [Parameter]
    public string? FacilityQuery { get; set; }

    [SupplyParameterFromQuery(Name = "parseStatus")]
    [Parameter]
    public string? ParseStatusQuery { get; set; }

    [SupplyParameterFromQuery(Name = "q")]
    [Parameter]
    public string? SearchTextQuery { get; set; }

    // 入力の解釈はサーバのタイムゾーン（ui.md §6 の契約の入力側。ラベルに明示する）。
    private static string ServerOffsetLabel =>
        YaguraTimeFormatter.FormatOffset(TimeZoneInfo.Local.GetUtcOffset(DateTimeOffset.UtcNow));

    private static string FromLabel =>
        string.Format(CultureInfo.InvariantCulture, UiText.SearchFieldFromFormat, ServerOffsetLabel);

    private static string ToLabel =>
        string.Format(CultureInfo.InvariantCulture, UiText.SearchFieldToFormat, ServerOffsetLabel);

    private DateTimeOffset? FromUtc => ToServerInstant(_from);
    private DateTimeOffset? ToUtc => ToServerInstant(_to);

    private bool HasAnyCondition =>
        _from is not null || _to is not null ||
        !string.IsNullOrWhiteSpace(_sourceAddress) ||
        _severityValue is not null ||
        _facilityValue is not null ||
        _parseStatusValue is not null ||
        !string.IsNullOrWhiteSpace(_searchText);

    private static RenderFragment NoResultsAction => builder =>
        builder.AddContent(0, UiText.SearchNoResultsNextAction);

    protected override void OnInitialized()
    {
        var status = StatusReader.ReadCurrent();
        _listeners = status.Listeners;
        _retentionHorizon = status.RetentionDays is { } days
            ? DateTimeOffset.UtcNow - TimeSpan.FromDays(days)
            : null;
    }

    protected override async Task OnParametersSetAsync()
    {
        // URL クエリを検索条件の正とする（初期表示・検索ボタン・ダッシュボードからの導線・
        // ブラウザの戻る/進む、いずれもここへ集約される）。絞り込みの強制はしない——
        // 条件なしなら条件なしの検索を自動実行する（architecture.md §6）。
        // 不正な値（改ざん・手編集された URL）は黙って「条件なし」として扱う——例外は出さない。
        _from = ParseServerWallClock(FromQuery);
        _to = ParseServerWallClock(ToQuery);
        _sourceAddress = string.IsNullOrEmpty(SourceQuery) ? null : SourceQuery;
        _severityValue = string.IsNullOrEmpty(SeverityQuery) ? null : SeverityQuery;
        _facilityValue = string.IsNullOrEmpty(FacilityQuery) ? null : FacilityQuery;
        _parseStatusValue = string.IsNullOrEmpty(ParseStatusQuery) ? null : ParseStatusQuery;
        _searchText = string.IsNullOrEmpty(SearchTextQuery) ? null : SearchTextQuery;

        await ExecuteSearchAsync();
    }

    /// <summary>
    /// 検索ボタンの押下ハンドラ。フォームの現在値を URL クエリへ反映して遷移するだけで、
    /// 実際の検索実行は <see cref="OnParametersSetAsync"/>（NavigateTo で再供給される
    /// SupplyParameterFromQuery パラメータ経由）に委ねる——二重実行を避ける単一経路。
    /// </summary>
    private void SubmitSearch() => Navigation.NavigateTo(BuildSearchUrl());

    private string BuildSearchUrl() =>
        QueryHelpers.AddQueryString("/search", BuildQueryParameters());

    /// <summary>
    /// CSV エクスポート（Issue #157）: 現在の検索条件を引き継いだクエリ付きで
    /// <c>/search/export.csv</c>（YaguraWebViewerExtensions.MapLogSearchCsvExport）へ
    /// 全ページ遷移する。クエリのキー・値は検索 URL（<see cref="BuildSearchUrl"/>）と
    /// 同一（<see cref="BuildQueryParameters"/> を共有——「今見ている検索と同じ条件」を
    /// 構造的に保証する）。
    /// </summary>
    private void ExportCsv() =>
        Navigation.NavigateTo(
            QueryHelpers.AddQueryString("/search/export.csv", BuildQueryParameters()),
            forceLoad: true);

    /// <summary>
    /// フォームの現在値から URL クエリパラメータ（Issue #148 の URL 共有形式）を組み立てる。
    /// 検索 URL（<see cref="BuildSearchUrl"/>）と CSV エクスポート URL（<see cref="ExportCsv"/>）で
    /// 同一のロジックを共有する（条件マッピングの二重管理を避ける）。
    /// </summary>
    private Dictionary<string, string?> BuildQueryParameters()
    {
        var query = new Dictionary<string, string?>();

        if (FromUtc is { } from)
        {
            query["from"] = FormatQueryTimestamp(from);
        }

        if (ToUtc is { } to)
        {
            query["to"] = FormatQueryTimestamp(to);
        }

        if (!string.IsNullOrWhiteSpace(_sourceAddress))
        {
            query["source"] = _sourceAddress.Trim();
        }

        if (_severityValue is { Length: > 0 })
        {
            query["severity"] = _severityValue;
        }

        if (_facilityValue is { Length: > 0 })
        {
            query["facility"] = _facilityValue;
        }

        if (_parseStatusValue is { Length: > 0 })
        {
            query["parseStatus"] = _parseStatusValue;
        }

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            query["q"] = _searchText;
        }

        return query;
    }

    // 期間はサーバ UTC の往復形式（"O"）で URL に載せる——サーバのタイムゾーンに依存せず、
    // 共有された URL がどの端末で開かれても同じ瞬間を指す（ui.md §6 の基準軸と同じ考え方）。
    private static string FormatQueryTimestamp(DateTimeOffset value) =>
        value.UtcDateTime.ToString("O", CultureInfo.InvariantCulture);

    private static DateTime? ParseServerWallClock(string? query)
    {
        if (string.IsNullOrEmpty(query))
        {
            return null;
        }

        if (!DateTimeOffset.TryParse(
                query,
                CultureInfo.InvariantCulture,
                DateTimeStyles.RoundtripKind | DateTimeStyles.AssumeUniversal,
                out var parsed))
        {
            return null;
        }

        return TimeZoneInfo.ConvertTime(parsed, TimeZoneInfo.Local).DateTime;
    }

    private async Task ExecuteSearchAsync()
    {
        _searching = true;
        _detailVisible = false;
        _detail = null;

        try
        {
            var results = await LogStore.QueryAsync(BuildLogQuery(cursor: null));
            _results = results;
            _hasMore = results.Count == SearchLimit;

            await LoadOutagesAndChartAsync(results);
        }
        finally
        {
            _searching = false;
        }
    }

    /// <summary>
    /// 「さらに読み込む」（database.md DB-11。カーソルページングの追記型 UI）: 現在の検索条件は
    /// そのまま、表示済みの最後の行のカーソルから続きを取得して末尾に追記する。カーソルは
    /// URL に載せない画面ローカルの状態のため、新しい検索（<see cref="SubmitSearch"/> による
    /// URL ナビゲーション → <see cref="OnParametersSetAsync"/>）が実行されると自然にリセットされる
    /// （_results が置き換わるため）。
    /// </summary>
    private async Task LoadMoreAsync()
    {
        if (_results is not { Count: > 0 } current || !_hasMore || _loadingMore)
        {
            return;
        }

        _loadingMore = true;

        try
        {
            var last = current[^1];
            var nextPage = await LogStore.QueryAsync(
                BuildLogQuery(cursor: new LogQueryCursor(last.ReceivedAt, last.Id)));

            var combined = current.Concat(nextPage).ToList();
            _results = combined;
            _hasMore = nextPage.Count == SearchLimit;

            // 追記した分だけ観測範囲が過去へ広がる——時間軸チャート・受信断区間も
            // 拡張後の全件（_results）を基準に再計算する（LoadOutagesAndChartAsync は
            // FromUtc 指定時はその下限を優先するため、期間指定検索では範囲は広がらない）。
            await LoadOutagesAndChartAsync(combined);
        }
        finally
        {
            _loadingMore = false;
        }
    }

    /// <summary>
    /// フォームの現在値から <see cref="LogQuery"/> を組み立てる（<see cref="ExecuteSearchAsync"/>・
    /// <see cref="LoadMoreAsync"/> で共有——条件マッピングの二重管理を避ける）。
    /// </summary>
    private LogQuery BuildLogQuery(LogQueryCursor? cursor) => new(
        Limit: SearchLimit,
        Timeout: SearchTimeout,
        ReceivedAtFrom: FromUtc,
        ReceivedAtTo: ToUtc,
        SourceAddress: string.IsNullOrWhiteSpace(_sourceAddress) ? null : _sourceAddress.Trim(),
        SeverityAtMost: TryParseInt(_severityValue),
        Facility: TryParseInt(_facilityValue),
        ParseStatus: TryParseParseStatus(_parseStatusValue),
        SearchText: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
        Cursor: cursor);

    private static int? TryParseInt(string? value) =>
        value is { Length: > 0 } && int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : null;

    private static ParseStatus? TryParseParseStatus(string? value) =>
        value is { Length: > 0 } && Enum.TryParse<ParseStatus>(value, out var parsed) ? parsed : null;

    private async Task LoadOutagesAndChartAsync(IReadOnlyList<LogRecordSummary> results)
    {
        // 時間軸の範囲: 指定範囲を優先し、未指定側は結果（または現在時刻）から補う。
        var now = DateTimeOffset.UtcNow;
        _chartRangeEnd = ToUtc ?? now;
        _chartRangeStart = FromUtc
            ?? (results.Count > 0 ? results.Min(r => r.ReceivedAt) : _chartRangeEnd - TimeSpan.FromHours(1));

        if (_chartRangeStart >= _chartRangeEnd)
        {
            _chartRangeStart = _chartRangeEnd - TimeSpan.FromMinutes(1);
        }

        var outages = await LogStore.QuerySystemEventsAsync(
            from: _chartRangeStart,
            to: _chartRangeEnd,
            limit: OutageQueryLimit,
            timeout: OutageQueryTimeout);
        var downtime = outages.Where(e => SystemEventKinds.IsDowntime(e.Kind)).ToList();

        // 保持地平より古い受信断区間は、保持地平の明示とセットでのみ見せる（ui.md §5.3 の
        // 誤読防止）。本画面は保持地平の通知を検索範囲が古い場合に必ず出すため（上部）、
        // 区間自体はそのまま列挙してよい——ただし通知の並び順で保持地平が先に立つ。
        _visibleOutages = downtime;
        _chartOutages = downtime
            .Select(e => new YaguraTimelineInterval(e.StartAt, e.EndAt, e.Approximate))
            .ToList();

        _chartBuckets = BuildBuckets(results, _chartRangeStart, _chartRangeEnd);
    }

    private static IReadOnlyList<YaguraTimelineBucket> BuildBuckets(
        IReadOnlyList<LogRecordSummary> records,
        DateTimeOffset rangeStart,
        DateTimeOffset rangeEnd)
    {
        var width = (rangeEnd - rangeStart) / ChartBucketCount;
        if (width <= TimeSpan.Zero)
        {
            return [];
        }

        var counts = new int[ChartBucketCount];
        foreach (var record in records)
        {
            var index = (int)((record.ReceivedAt - rangeStart) / width);
            if (index >= 0 && index < counts.Length)
            {
                counts[index]++;
            }
            else if (index == counts.Length)
            {
                // 上端ちょうど（ReceivedAt == rangeEnd）は最終区切りに含める。
                counts[^1]++;
            }
        }

        var buckets = new List<YaguraTimelineBucket>(counts.Length);
        for (var i = 0; i < counts.Length; i++)
        {
            var start = rangeStart + i * width;
            var end = i == counts.Length - 1 ? rangeEnd : start + width;
            buckets.Add(new YaguraTimelineBucket(start, end, counts[i]));
        }

        return buckets;
    }

    // 詳細オーバーレイ(モーダル)の可視状態と表示オプション。Esc・背景クリックで閉じられる。
    private bool _detailVisible;
    private static readonly DialogOptions _detailDialogOptions = new()
    {
        CloseOnEscapeKey = true,
        BackdropClick = true,
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
    };

    private async Task ShowDetailAsync(LogRecordSummary summary)
    {
        _detail = await LogStore.FindByIdAsync(summary.Id, DetailTimeout);
        _detailVisible = true;
    }

    private void CloseDetail()
    {
        _detailVisible = false;
        _detail = null;
    }

    private bool SearchReachesBeyondHorizon(DateTimeOffset horizon) =>
        // 下限なし（無限に過去へ届く）または下限が保持地平より古い場合に明示する。
        FromUtc is null || FromUtc < horizon;

    private static string ListenerLabel(YaguraListenerEndpoint listener) =>
        string.Format(CultureInfo.InvariantCulture, UiText.ListenerPortLabelFormat, listener.ProtocolName);

    private DateTimeOffset? ToServerInstant(DateTime? wallClock) =>
        wallClock is { } value
            ? new DateTimeOffset(value, TimeZoneInfo.Local.GetUtcOffset(value))
            : null;

    private static string SummaryMessage(LogRecordSummary record) => record.ParseStatus switch
    {
        ParseStatus.ParseFailed => UiText.ParseFailedLabel,
        ParseStatus.Incomplete => UiText.IncompleteLabel,
        _ => record.Message ?? string.Empty,
    };

    private static string RawAsText(byte[] raw) =>
        // 不正 UTF-8 を含み得るため置換文字で無害化して表示する（保存自体はバイト列のまま——
        // database.md §2.1。ここは表示のみ）。
        System.Text.Encoding.UTF8.GetString(raw);

    // ---- 装置時計ずれの明示（ui.md §6・Issue #158） ----

    // 乖離表示の閾値（仮値。UI-2——ステール警告の閾値（Dashboard.razor・YaguraStaleGuard）と同じ
    // 「仮値で実装し、実利用で確定する」の流儀）。Issue #158 に具体的な提案値がなかったため、
    // 実務者が詳細を開いて気づく水準として 5 分を仮に置く。
    internal static readonly TimeSpan DeviceTimestampDriftThreshold = TimeSpan.FromMinutes(5);

    /// <summary>
    /// 装置時計ずれの注記文言を組み立てる（乖離が <see cref="DeviceTimestampDriftThreshold"/>
    /// 未満、または DeviceTimestamp 自体が未設定の場合は null——注記を出さない）。
    /// </summary>
    /// <remarks>
    /// <b>RFC 3164（タイムゾーン情報なし）由来レコードの扱い（2026-07-09 判断）</b>:
    /// 受信段（Yagura.Ingestion.Parsing.SyslogParser）の RFC 3164 解析は TIMESTAMP に
    /// タイムゾーン情報がないため UTC とみなす近似で DeviceTimestamp を組み立てる
    /// （database.md §2.1「参考情報。基準軸にしない」）。装置が実際には UTC 以外のタイムゾーンで
    /// 動作している場合、この乖離は真の時計ずれではなく送信元のタイムゾーン設定の違いを表す
    /// ことがある。<see cref="LogRecord"/> には RFC バージョンを判別できる永続化済み情報がなく
    /// （StructuredData の有無は RFC 5424 でも無記載があり得るため信頼できる判別に使えない）、
    /// レコード単位でこの注記を出し分けることはできない。そのため本メソッドは常に同じ規則
    /// （単純な差分 + 閾値）で注記を出し、原因の曖昧さは <see cref="UiText.DetailDeviceTimestampDriftSupplement"/>
    /// の補足文言で明示する側に倒す（値を隠す・出し分けを誤って行うより、限界を明示したうえで
    /// 常時見せる方が実務者の判断材料になる——ui.md §6 の趣旨「装置の時計ずれの発見に使う」に
    /// も、RFC 3164 機器のタイムゾーン誤設定の発見にも資する）。
    /// </remarks>
    internal static string? BuildDeviceTimestampDriftNote(DateTimeOffset receivedAt, DateTimeOffset? deviceTimestamp)
    {
        if (deviceTimestamp is not { } device)
        {
            return null;
        }

        var drift = device - receivedAt;
        var magnitude = drift < TimeSpan.Zero ? -drift : drift;
        if (magnitude < DeviceTimestampDriftThreshold)
        {
            return null;
        }

        var format = drift > TimeSpan.Zero
            ? UiText.DetailDeviceTimestampDriftAheadFormat
            : UiText.DetailDeviceTimestampDriftBehindFormat;

        return string.Format(CultureInfo.InvariantCulture, format, FormatDriftMagnitude(magnitude));
    }

    private static string FormatDriftMagnitude(TimeSpan magnitude) => magnitude switch
    {
        { TotalDays: >= 1 } => string.Create(CultureInfo.InvariantCulture, $"{(int)magnitude.TotalDays} 日 {magnitude.Hours} 時間"),
        { TotalHours: >= 1 } => string.Create(CultureInfo.InvariantCulture, $"{(int)magnitude.TotalHours} 時間 {magnitude.Minutes} 分"),
        _ => string.Create(CultureInfo.InvariantCulture, $"{(int)magnitude.TotalMinutes} 分"),
    };
}
