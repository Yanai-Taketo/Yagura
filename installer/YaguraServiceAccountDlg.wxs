<!--
  サービス実行アカウントを指定するダイアログ(ADR-0015 決定 2 / configuration.md §4.4 の
  gMSA opt-in UI。Issue #263)。レイアウトは YaguraFirewallDlg と同じく WixUI 標準ダイアログを
  雛形にした。入力欄は公開プロパティ YAGURA_SERVICE_ACCOUNT(Package.wxs で既定値
  NT SERVICE\Yagura)に束縛する。

  パスワード欄は意図的に設けない(ADR-0015 決定 2): gMSA は空パスワードでのサービス登録が
  仕様であり、パスワード欄の不在自体が「手動管理アカウントを想定しない」設計意図の表明になる。

  入力値の検証はここでは行わない(MSI の UI 層に形式検証の手段がない): 実行シーケンス冒頭の
  type 19 エラー CA(Package.wxs の ValidateYaguraServiceAccount)が対話・サイレント共通の
  fail-closed 検証を担う(不正値は「インストール」開始直後にエラーで停止する)。
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Fragment>
        <UI>
            <Dialog Id="YaguraServiceAccountDlg" Width="370" Height="270" Title="!(loc.YaguraServiceAccountDlg_Title)">
                <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
                <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
                <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
                    <Publish Event="SpawnDialog" Value="CancelDlg" />
                </Control>

                <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.YaguraServiceAccountDlgDescription)" />
                <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.YaguraServiceAccountDlgTitle)" />
                <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
                <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="373" Height="0" />
                <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="373" Height="0" />

                <Control Id="DefaultNote" Type="Text" X="20" Y="60" Width="330" Height="34" NoPrefix="yes"
                         Text="!(loc.YaguraServiceAccountDlgDefaultNote)" />

                <Control Id="AccountLabel" Type="Text" X="20" Y="100" Width="330" Height="12" NoPrefix="yes"
                         Text="!(loc.YaguraServiceAccountDlgAccountLabel)" />
                <!-- Text="{80}" は入力長の上限(WixUI 標準の Edit コントロールの作法)。 -->
                <Control Id="AccountEdit" Type="Edit" X="20" Y="114" Width="240" Height="16"
                         Property="YAGURA_SERVICE_ACCOUNT" Text="{80}" />

                <Control Id="GmsaNote" Type="Text" X="20" Y="140" Width="330" Height="88" NoPrefix="yes"
                         Text="!(loc.YaguraServiceAccountDlgGmsaNote)" />
            </Dialog>
        </UI>
    </Fragment>
</Wix>
