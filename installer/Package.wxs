<!--
  Yagura MSI インストーラ本体(M9-1。Issue #74)。

  責務(configuration.md §4.3 / ADR-0004 決定 4・5):
  - Windows サービス登録(仮想サービスアカウント NT SERVICE\Yagura・自動起動・失敗時再起動)
  - データルート %ProgramData%\Yagura の作成 + ACL(security.md §5 の ACE 構成)
  - フォワーダ MSI 配置フォルダ %ProgramData%\Yagura\forwarder の作成 + 明示 ACL
    (Administrators のみ書込可。ADR-0008 設計条件 9・security.md §5.1・Issue #171)
  - ファイアウォール規則(UDP 514 / TCP 514 / TCP 8514。オプトアウト可。Firewall.wxs)
  - イベントログソース "Yagura" の事前登録(Program.cs の M9 申し送り)
  - 完了画面での閲覧 URL 案内 + スタートメニューリンク
  - MajorUpgrade の基本定義
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="Yagura"
           Manufacturer="Yagura Project"
           Version="0.2.1"
           UpgradeCode="2BF11897-147B-4770-8071-399158378C7E"
           Language="1041"
           Scope="perMachine"
           InstallerVersion="500"
           Compressed="yes">
    <!-- InstallerVersion 500(MSI 5.0)の根拠: データルート ACL に用いる native の
         PermissionEx(MsiLockPermissionsEx テーブル)は公式ドキュメントに
         "This element is only available when installing with MSI 5.0." と明記されている
         (docs.firegiant.com/wix/schema/wxs/permissionex/、確認日 2026-07-06)。
         ServiceConfigFailureActions も同じく MSI 5.0 以降。 -->

    <!-- 注意: MSI データベースのコードページは 932(Shift_JIS)。CP932 に存在しない文字
         (U+2014 の em ダッシュ等)を MSI に入る文字列へ使うと WIX0311 になる(実ビルドで確認)。 -->
    <SummaryInformation Description="Yagura : Windows ネイティブ syslog 集約サーバ" />

    <!--
      MajorUpgrade: アップグレードの基本定義。
      Schedule は既定値(afterInstallValidate)のまま明示しない。公式ドキュメント引用
      (docs.firegiant.com/wix/schema/wxs/majorupgrade/、確認日 2026-07-06):
        "The default is 'afterInstallValidate' which removes the installed product
         entirely before installing the upgrade product. It's slowest but gives the
         most flexibility in changing components and features in the upgrade product."
        "Note that if the installation of the upgrade product fails, the machine will
         have neither version installed."
      データ・設定の保持: データルート(%ProgramData%\Yagura 配下の yagura.json・組み込み DB・
      スプール等)は MSI のコンポーネントとして追跡されないため、旧製品の削除でも消えない
      (MSI が削除するのは自身がインストールしたリソースのみ)。旧リポジトリの trap
      (Permanent="yes" vs REINSTALLMODE の同等性主張)を踏まないよう、本 PR では
      REINSTALLMODE への言及・変更を一切行わず、既定挙動のみで構成する。
      実機でのアップグレード挙動検証(設定・DB が残ること)は M9-3 lab の受け入れ条件。
    -->
    <MajorUpgrade DowngradeErrorMessage="!(loc.DowngradeErrorMessage)" />

    <MediaTemplate EmbedCab="yes" />

    <!-- ファイアウォール規則のオプトアウト(configuration.md §4.3)。
         既定 = 規則を作成する(1)。UI のチェックボックス(YaguraFirewallDlg)または
         サイレントインストール時の msiexec プロパティ(YAGURA_FIREWALL="")で解除できる。
         実行シーケンス(elevated)のコンポーネント条件で参照するため Secure="yes"
         (SecureCustomProperties への登録)が必須。 -->
    <Property Id="YAGURA_FIREWALL" Value="1" Secure="yes" />

    <!-- 完了画面(ExitDialog): 閲覧 URL の案内テキスト + 「ブラウザで開く」チェックボックス
         (WixUI 公式のカスタマイズ機構。docs.firegiant.com/wix/tools/wixext/wixui/
         「Adding text or a checkbox to the completion dialog」、確認日 2026-07-06)。 -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALTEXT" Value="!(loc.ExitDialogViewerText)" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="!(loc.ExitDialogLaunchCheckBox)" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />

    <!-- チェックボックス ON のとき既定ブラウザで閲覧 URL を開く。
         WixShellExec は Util 拡張の custom action で、実装は ShellExecuteW にターゲットを
         そのまま渡す(wixtoolset/wix v7.0.0 の src/ext/Util/ca/shellexecca.cpp を直接確認。
         URL は OS のプロトコル関連付けで既定ブラウザが開く。確認日 2026-07-06)。 -->
    <Property Id="WixShellExecTarget" Value="http://localhost:8514/" />
    <CustomAction Id="LaunchYaguraViewer"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixShellExec"
                  Execute="immediate"
                  Return="check"
                  Impersonate="yes" />

    <!-- ダイアログ列: Welcome → License → InstallDir → Firewall → VerifyReady
         (WixUI_InstallDir を公式手順どおり複製し YaguraFirewallDlg を挿入。
         WixUI_YaguraInstallDir.wxs 参照)。 -->
    <ui:WixUI Id="WixUI_YaguraInstallDir" InstallDirectory="INSTALLFOLDER" />

    <Feature Id="Main" Title="Yagura" Level="1">
      <ComponentGroupRef Id="HostPublishFiles" />
      <ComponentRef Id="HostServiceExe" />
      <ComponentRef Id="EventLogMessages" />
      <ComponentRef Id="DataRootFolder" />
      <ComponentRef Id="ForwarderFolder" />
      <ComponentRef Id="FirewallInstallRecord" />
      <ComponentRef Id="FirewallRules" />
      <ComponentRef Id="ViewerShortcut" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Yagura" />
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <!-- データルート(configuration.md §2: 既定 %ProgramData%\Yagura)。 -->
      <Directory Id="YaguraDataRoot" Name="Yagura">
        <!-- フォワーダ MSI 配置フォルダ(ADR-0008 設計条件 9・Issue #171)。
             データルートの ACL をそのまま継承すると、サービスアカウントに書込権限が
             残ってしまう(下の ForwarderFolder コンポーネントで明示 ACL に上書きする)。 -->
        <Directory Id="YaguraForwarderFolder" Name="forwarder" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="YaguraMenuFolder" Name="Yagura" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <!-- Yagura.Host の publish 出力一式(サービス本体の exe と、イベントソースの
         メッセージファイルに使う DLL は下の明示コンポーネントに分離)。 -->
    <ComponentGroup Id="HostPublishFiles" Directory="INSTALLFOLDER">
      <Files Include="$(PublishDir)\**">
        <Exclude Files="$(PublishDir)\Yagura.Host.exe" />
        <Exclude Files="$(PublishDir)\System.Diagnostics.EventLog.Messages.dll" />
      </Files>
    </ComponentGroup>

    <Component Id="HostServiceExe" Directory="INSTALLFOLDER">
      <File Id="Yagura.Host.exe" Source="$(PublishDir)\Yagura.Host.exe" KeyPath="yes" />

      <!--
        Windows サービス登録(ADR-0004 決定 4: 仮想サービスアカウント NT SERVICE\Yagura を
        既定とし LocalSystem では動かさない)。サービス名 "Yagura" は
        Program.WindowsServiceName 定数と一致させる(src/Yagura.Host/Program.cs)。
        Account の指定形式(NT SERVICE\<サービス名>)が MSI の ServiceInstall 経由で
        成立するかは実機依存のため M9-3 lab の検証項目とする。
      -->
      <ServiceInstall Id="YaguraService"
                      Name="Yagura"
                      DisplayName="Yagura"
                      Description="!(loc.ServiceDescription)"
                      Type="ownProcess"
                      Start="auto"
                      ErrorControl="normal"
                      Account="NT SERVICE\Yagura"
                      Vital="yes">
        <!--
          失敗時再起動ポリシー: 再起動時間 = ロス時間(architecture.md §1.2)のため、
          3 回まで 5 秒後に自動再起動する。M3 はポリシー値を確定していないため本値は
          インストーラ側の提案値であり、M9-3 lab で挙動確認のうえ確定する。
          native の ServiceConfigFailureActions は WiX 7.0.0 のビルドがエラー WIX1149
          「ServiceConfigFailureActions functionality is documented in the Windows
          Installer SDK to "not [work] as expected." Consider replacing ... with the
          WixToolset.Util.wixext ServiceConfig element.」で拒否する(実ビルドで確認、
          2026-07-06)ため、WiX 公式の推奨どおり util:ServiceConfig(custom action 方式)
          を採用する(スキーマ: docs.firegiant.com/wix/schema/util/serviceconfig/)。
        -->
        <util:ServiceConfig FirstFailureActionType="restart"
                            SecondFailureActionType="restart"
                            ThirdFailureActionType="restart"
                            RestartServiceDelayInSeconds="5"
                            ResetPeriodInDays="1" />
      </ServiceInstall>

      <ServiceControl Id="YaguraServiceControl"
                      Name="Yagura"
                      Start="install"
                      Stop="both"
                      Remove="uninstall"
                      Wait="yes" />
    </Component>

    <!--
      イベントログソース "Yagura" の事前登録(Program.cs の M9 申し送り: ソース未登録だと
      EventLog プロバイダが縮退する)。メッセージファイルには publish 出力に含まれる
      System.Diagnostics.EventLog.Messages.dll(.NET の EventLog が既定で使う "%1" 形式の
      メッセージリソース)を使う。
    -->
    <Component Id="EventLogMessages" Directory="INSTALLFOLDER">
      <File Id="EventLogMessagesDll" Source="$(PublishDir)\System.Diagnostics.EventLog.Messages.dll" KeyPath="yes" />
      <util:EventSource Log="Application" Name="Yagura" EventMessageFile="[#EventLogMessagesDll]" />
    </Component>

    <!--
      データルート作成 + ACL(ADR-0004 決定 5 / security.md §5)。
      実装方式の判断: Yagura.Host 側に ACL 設定処理は存在せず(実行時アカウントは
      仮想サービスアカウントで、ProgramData 直下に自力で ACL を張る権限も持たない)、
      util:PermissionEx(custom action 方式)は「既存 ACL への追加」であり継承 ACE の
      持ち込みを禁じる security.md §5 を表現できないため、native の PermissionEx
      (MsiLockPermissionsEx。SDDL でセキュリティ記述子を直接指定)を採用する。

      SDDL の内訳(security.md §5 の ACE 構成の直訳):
        D:P                        … DACL 保護(上位フォルダからの継承を無効化)
        (A;OICI;FA;;;SY)           … SYSTEM = フルコントロール(配下へ継承)
        (A;OICI;FA;;;BA)           … Administrators = フルコントロール(同上)
        (A;OICI;0x1301bf;;;S-1-5-80-…) … サービスアカウント = 変更(Modify。
                                      FILE_GENERIC_READ|WRITE|EXECUTE|DELETE = 0x1301bf。
                                      ACL 自体の変更権限 WRITE_DAC/WRITE_OWNER は含まない)
      S-1-5-80-… は NT SERVICE\Yagura の SID。仮想サービスアカウントの SID はサービス名から
      決定的に導出されるため全マシンで同一(本環境で `sc.exe showsid Yagura` により
      サービス未登録状態で取得できることを確認済み = 名前のみから導出される証跡。
      確認日 2026-07-06)。適用結果の icacls 出力による確定は SEC-3(M9-3 lab)。
    -->
    <!-- CreateFolder を KeyPath とするコンポーネントは GUID 自動生成の対象外
         (WIX0230。実ビルドで確認)のため明示 GUID を与える。 -->
    <Component Id="DataRootFolder" Directory="YaguraDataRoot" Guid="F8857077-4311-4A8C-8372-1D478D98A976">
      <CreateFolder>
        <PermissionEx Sddl="D:P(A;OICI;FA;;;SY)(A;OICI;FA;;;BA)(A;OICI;0x1301bf;;;S-1-5-80-2906685102-3215373564-3806320331-1391897514-1145735297)" />
      </CreateFolder>
    </Component>

    <!--
      フォワーダ MSI 配置フォルダの作成 + 明示 ACL(ADR-0008 設計条件 9・security.md §5.1・
      Issue #171)。データルート配下だが、DataRootFolder と同じ ACE 構成をそのまま継承すると
      サービスアカウントに書込権限が残ってしまう(#171 で icacls 確認により判明した乖離)。
      設計条件 9 は「Administrators のみ書込可」を意図しているため、DataRootFolder と同じ
      native PermissionEx(MsiLockPermissionsEx)で継承を明示的に断ち切り、
      サービスアカウントには読み取り専用の ACE のみを与える。

      設定タイミングをインストーラ側に置いた理由: DataRootFolder が同じ native PermissionEx
      方式で ACL を確定させており(コメント参照)、そこに合わせるのが最小の変更半径になる。
      サービス起動時(Yagura.Host 側)に ACL を設定する代替も検討したが、(1) 実行時アカウント
      (仮想サービスアカウント)は ProgramData 直下に自力で ACL を張る権限を持たない
      (DataRootFolder コメントと同じ理由)、(2) フォルダ作成・ACL 確定の責務をインストーラに
      一本化したほうが「適用はインストーラが行い、サービスは起動時に検証する」という
      security.md §5 の既定方針とも一致するため、インストーラ側を採用する。

      フォルダが存在しない場合の扱い: DataRootFolder と同様、CreateFolder で**常に作成する**
      (存在時のみ適用、ではない)。理由: (1) DataRootFolder との対称性(データルート配下の
      サブフォルダの作成方式を分岐させない)、(2) 管理者が生成 UI の案内(パス表示)を見て
      MSI を配置しようとした時点で、既に正しい ACL のフォルダが存在している状態にできる
      (利用者ガイドの「初回は管理者が自分で作成する」という手作業を不要にする)。

      SDDL の内訳(DataRootFolder との差分はサービスアカウントの権限のみ):
        D:P                        … DACL 保護(データルートからの継承 ACE を持ち込まない)
        (A;OICI;FA;;;SY)           … SYSTEM = フルコントロール(配下へ継承)
        (A;OICI;FA;;;BA)           … Administrators = フルコントロール(同上)
        (A;OICI;0x120089;;;S-1-5-80-…) … サービスアカウント = 読み取りのみ
                                      (FILE_GENERIC_READ = 0x120089。書込・削除・ACL 変更の
                                      いずれも与えない)。SystemForwarderMsiSource
                                      (src/Yagura.Web/ForwarderKit/SystemForwarderMsiSource.cs)は
                                      フォルダの列挙・ファイルのハッシュ計算・MSI 版取得のみを
                                      行う読み取り専用の実装であり、書込は一切行わないため
                                      Read で動作に支障はない
      SID は DataRootFolder と同じ NT SERVICE\Yagura の SID(サービス名から決定的に導出される
      ため全マシンで同一。DataRootFolder コメント参照)。

      実機確認(2026-07-09、Issue #171 実装 PR): msiexec /qn でインストール後、
      `icacls %ProgramData%\Yagura\forwarder` が意図どおり
      `NT AUTHORITY\SYSTEM:(OI)(CI)(F)` / `BUILTIN\Administrators:(OI)(CI)(F)` /
      `NT SERVICE\Yagura:(OI)(CI)(R)` を返すことを確認。データルート本体は
      `NT SERVICE\Yagura:(OI)(CI)(M)` のままで、forwarder フォルダのみ `(R)` に絞られている
      ことも確認済み。Administrators で `fluent-bit-*-win64.msi` パターンのファイルを配置した
      状態で `/admin/forwarder-kit`(NT SERVICE\Yagura で稼働する Yagura.Host)にアクセスし、
      MSI が「未検出」にならず正しく検出されることを確認——サービスアカウントの読み取り専用
      ACE で SystemForwarderMsiSource(列挙・SHA256・ProductVersion の読み取り)が支障なく
      動作することを実機で確認した。アンインストール時、フォルダが空なら DataRootFolder と
      同様に削除され、MSI 配置済み(非空)なら保持されることも確認済み(ACL も保持されたまま)。
    -->
    <Component Id="ForwarderFolder" Directory="YaguraForwarderFolder" Guid="42FE74EC-C5CB-4E46-BB03-AC56C5D0EFF6">
      <CreateFolder>
        <PermissionEx Sddl="D:P(A;OICI;FA;;;SY)(A;OICI;FA;;;BA)(A;OICI;0x120089;;;S-1-5-80-2906685102-3215373564-3806320331-1391897514-1145735297)" />
      </CreateFolder>
    </Component>

    <!--
      スタートメニューの閲覧リンク(configuration.md §4.3「30 分動線を閉じる」)。
      util:InternetShortcut は .url ファイルを生成する(公式スキーマ: Type="url" は
      "Creates .url files using IUniformResourceLocatorW.")。
    -->
    <Component Id="ViewerShortcut" Directory="YaguraMenuFolder">
      <util:InternetShortcut Id="ViewerUrlShortcut"
                             Name="!(loc.ViewerShortcutName)"
                             Target="http://localhost:8514/"
                             Type="url" />
      <!-- ICE38: ユーザープロファイル配下(スタートメニュー)へインストールする
           コンポーネントの KeyPath は HKCU 配下でなければならない(実ビルドの ICE 検証で
           確認)。per-machine インストールでも HKCU KeyPath がショートカットの定石。 -->
      <RegistryValue Root="HKCU" Key="SOFTWARE\Yagura" Name="ViewerShortcut" Type="integer" Value="1" KeyPath="yes" />
      <RemoveFolder Id="RemoveYaguraMenuFolder" On="uninstall" />
    </Component>
  </Fragment>

</Wix>
