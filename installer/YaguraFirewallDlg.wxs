<!--
  ファイアウォール規則の作成可否を選ぶダイアログ(configuration.md §4.3 のオプトアウト UI)。
  レイアウトは WixUI 標準ダイアログ(wixtoolset/wix v7.0.0 の InstallDirDlg.wxs)を雛形にした。
  チェックボックスは公開プロパティ YAGURA_FIREWALL(Package.wxs で既定値 1)に束縛する。
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Fragment>
        <UI>
            <Dialog Id="YaguraFirewallDlg" Width="370" Height="270" Title="!(loc.YaguraFirewallDlg_Title)">
                <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
                <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
                <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
                    <Publish Event="SpawnDialog" Value="CancelDlg" />
                </Control>

                <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.YaguraFirewallDlgDescription)" />
                <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="!(loc.YaguraFirewallDlgTitle)" />
                <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
                <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="373" Height="0" />
                <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="373" Height="0" />

                <Control Id="FirewallCheckBox" Type="CheckBox" X="20" Y="60" Width="330" Height="18"
                         Property="YAGURA_FIREWALL" CheckBoxValue="1"
                         Text="!(loc.YaguraFirewallDlgCheckBox)" />

                <Control Id="RuleListLabel" Type="Text" X="30" Y="84" Width="320" Height="60" NoPrefix="yes"
                         Text="!(loc.YaguraFirewallDlgRuleList)" />

                <Control Id="OptOutNote" Type="Text" X="20" Y="150" Width="330" Height="70" NoPrefix="yes"
                         Text="!(loc.YaguraFirewallDlgOptOutNote)" />
            </Dialog>
        </UI>
    </Fragment>
</Wix>
